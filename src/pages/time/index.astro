---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import { TIME_TOOLS } from '../../data/time/index';
import { breadcrumbSchema, collectionPageSchema, faqSchema } from '../../lib/schema';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Date & Time', url: '/time/' },
];

const faqs = [
  {
    q: 'Are these calculations accurate across leap years and DST?',
    a: 'Yes — everything runs on the browser\'s own calendar and timezone engines: leap days come from real calendar arithmetic, and timezone conversions use the IANA database your operating system also uses, so daylight-saving transitions are applied automatically.',
  },
  {
    q: 'Why run date tools client-side?',
    a: 'Dates are quietly personal — birthdates, deadlines, medical appointments, contract dates. There is no reason a subtraction between two dates should travel to a server. Here it never does; the tools even work offline.',
  },
  {
    q: 'Do the tools use my computer\'s timezone?',
    a: 'Local-time displays use your device\'s timezone setting, and UTC is shown alongside where it matters (timestamps). The timezone converter lets you pick both zones explicitly.',
  },
];

const schema = [
  breadcrumbSchema(crumbs),
  collectionPageSchema({
    name: 'Free Date & Time Tools',
    url: '/time/',
    description: 'Unix timestamp converter, age calculator, days between dates, date add/subtract, ISO week numbers and timezone converter — all running locally in your browser.',
    items: TIME_TOOLS.map((t) => ({ name: t.name, url: `/time/${t.slug}/` })),
  }),
  faqSchema(faqs),
];
---

<Base
  title="Date & Time Tools — Timestamps, Age, Durations | LazyTools"
  description={`${TIME_TOOLS.length} free date & time tools: Unix timestamp converter, exact age calculator, days between dates, date arithmetic, ISO week numbers, timezone converter. All client-side.`}
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Date & Time Tools</h1>
    <p class="mt-3 max-w-3xl text-lg leading-relaxed text-slate-700">
      Timestamps, ages, durations, deadlines and timezones — computed with the browser's own
      calendar and IANA timezone engines, so leap years and daylight saving are handled the way
      your operating system handles them. Nothing you enter leaves your device.
    </p>

    <div class="mt-5">
      <PrivacyStrip />
    </div>

    <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {TIME_TOOLS.map((t) => (
        <li>
          <a href={`/time/${t.slug}/`} class="flex h-full flex-col rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
            <span class="text-2xl" aria-hidden="true">{t.icon}</span>
            <span class="mt-2 font-semibold text-slate-900">{t.name}</span>
            <span class="mt-1 text-sm text-slate-600">{t.lead.split('—')[0]}</span>
          </a>
        </li>
      ))}
    </ul>

    <FaqSection faqs={faqs} />
  </div>
</Base>
