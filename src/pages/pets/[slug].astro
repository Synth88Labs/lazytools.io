---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import DogAgeTool from '../../components/pets/DogAgeTool.tsx';
import CatAgeTool from '../../components/pets/CatAgeTool.tsx';
import PetFoodTool from '../../components/pets/PetFoodTool.tsx';
import GestationTool from '../../components/pets/GestationTool.tsx';
import AquariumTool from '../../components/pets/AquariumTool.tsx';
import WaterIntakeTool from '../../components/pets/WaterIntakeTool.tsx';
import CrateSizeTool from '../../components/pets/CrateSizeTool.tsx';
import ChocolateToxicityTool from '../../components/pets/ChocolateToxicityTool.tsx';
import { PET_TOOLS, type PetToolDef } from '../../data/pets/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return PET_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: PetToolDef = PET_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pets & Animals', url: '/pets/' },
  { name: tool.name, url: `/pets/${tool.slug}/` },
];

const related = PET_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/pets/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/pets/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`pets/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'dogage' && <DogAgeTool client:load />}
      {tool.widget === 'catage' && <CatAgeTool client:load />}
      {tool.widget === 'dogfood' && <PetFoodTool species="dog" client:load />}
      {tool.widget === 'catfood' && <PetFoodTool species="cat" client:load />}
      {tool.widget === 'gestation' && <GestationTool client:load />}
      {tool.widget === 'aquarium' && <AquariumTool client:load />}
      {tool.widget === 'water' && <WaterIntakeTool client:load />}
      {tool.widget === 'crate' && <CrateSizeTool client:load />}
      {tool.widget === 'choctox' && <ChocolateToxicityTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`pets/${tool.slug}`}
        avg={ratingFor(`pets/${tool.slug}`)?.avg}
        count={ratingFor(`pets/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related pet tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/pets/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/pets/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All pet tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
