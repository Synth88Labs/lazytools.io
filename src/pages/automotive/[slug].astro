---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import TireSizeTool from '../../components/automotive/TireSizeTool.tsx';
import TireCompareTool from '../../components/automotive/TireCompareTool.tsx';
import GearRatioTool from '../../components/automotive/GearRatioTool.tsx';
import DisplacementTool from '../../components/automotive/DisplacementTool.tsx';
import CompressionTool from '../../components/automotive/CompressionTool.tsx';
import HorsepowerTool from '../../components/automotive/HorsepowerTool.tsx';
import FuelEconomyTool from '../../components/automotive/FuelEconomyTool.tsx';
import WheelOffsetTool from '../../components/automotive/WheelOffsetTool.tsx';
import EvChargingTool from '../../components/automotive/EvChargingTool.tsx';
import PowerToWeightTool from '../../components/automotive/PowerToWeightTool.tsx';
import StoppingDistanceTool from '../../components/automotive/StoppingDistanceTool.tsx';
import QuarterMileTool from '../../components/automotive/QuarterMileTool.tsx';
import FuelCostTool from '../../components/automotive/FuelCostTool.tsx';
import { AUTO_TOOLS, type AutoToolDef } from '../../data/automotive/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return AUTO_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: AutoToolDef = AUTO_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Automotive', url: '/automotive/' },
  { name: tool.name, url: `/automotive/${tool.slug}/` },
];

const related = AUTO_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/automotive/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/automotive/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`automotive/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'tire' && <TireSizeTool client:load />}
      {tool.widget === 'tirecompare' && <TireCompareTool client:load />}
      {tool.widget === 'gear' && <GearRatioTool client:load />}
      {tool.widget === 'displacement' && <DisplacementTool client:load />}
      {tool.widget === 'compression' && <CompressionTool client:load />}
      {tool.widget === 'hp' && <HorsepowerTool client:load />}
      {tool.widget === 'fueleconomy' && <FuelEconomyTool client:load />}
      {tool.widget === 'offset' && <WheelOffsetTool client:load />}
      {tool.widget === 'evcharge' && <EvChargingTool client:load />}
      {tool.widget === 'pwr2wt' && <PowerToWeightTool client:load />}
      {tool.widget === 'stopping' && <StoppingDistanceTool client:load />}
      {tool.widget === 'quartermile' && <QuarterMileTool client:load />}
      {tool.widget === 'fuelcost' && <FuelCostTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`automotive/${tool.slug}`}
        avg={ratingFor(`automotive/${tool.slug}`)?.avg}
        count={ratingFor(`automotive/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related automotive tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/automotive/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/automotive/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All automotive tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
