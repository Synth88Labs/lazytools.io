---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import { DEV_TOOLS } from '../../data/dev/index';
import { breadcrumbSchema, collectionPageSchema, faqSchema } from '../../lib/schema';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Developer Tools', url: '/dev/' },
];

const faqs = [
  {
    q: 'Why does client-side matter especially for developer tools?',
    a: 'Because the inputs are secrets: JWTs are live credentials, Base64 blobs are often API payloads, and hashed strings can be keys. Pasting those into a server-backed tool hands them to that server. Every tool here runs locally — verify with the network tab or by going offline.',
  },
  {
    q: 'Do these tools match what my code does?',
    a: 'Yes, by construction: the regex tester runs the browser\'s actual RegExp engine, hashing uses the native Web Crypto implementation, and Base64/URL encoding use the platform functions with correct UTF-8 handling.',
  },
  {
    q: 'Why is there no MD5?',
    a: 'The Web Crypto API excludes it deliberately — MD5 collisions are practical, so it fails as a security primitive. SHA-256 is the modern default for everything MD5 used to do.',
  },
];

const schema = [
  breadcrumbSchema(crumbs),
  collectionPageSchema({
    name: 'Free Developer Tools',
    url: '/dev/',
    description: 'Base64, URL and HTML encoding, SHA hashes, JWT decoder, regex tester and number base converter — all running locally in your browser.',
    items: DEV_TOOLS.map((t) => ({ name: t.name, url: `/dev/${t.slug}/` })),
  }),
  faqSchema(faqs),
];
---

<Base
  title="Developer Tools — Encoders, Hashes, Regex | LazyTools"
  description={`${DEV_TOOLS.length} free developer tools: Base64, URL and HTML encoding, SHA hash generator, JWT decoder, regex tester, number base converter. Tokens and payloads never leave your browser.`}
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Developer Tools</h1>
    <p class="mt-3 max-w-3xl text-lg leading-relaxed text-slate-700">
      Encode, decode, hash and test — with the browser's own engines, so results match your code
      exactly. Tokens, payloads and secrets are exactly what shouldn't touch third-party servers:
      here they never do.
    </p>

    <div class="mt-5">
      <PrivacyStrip />
    </div>

    <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {DEV_TOOLS.map((t) => (
        <li>
          <a href={`/dev/${t.slug}/`} class="flex h-full flex-col rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
            <span class="text-2xl" aria-hidden="true">{t.icon}</span>
            <span class="mt-2 font-semibold text-slate-900">{t.name}</span>
            <span class="mt-1 text-sm text-slate-600">{t.lead.split('—')[0]}</span>
          </a>
        </li>
      ))}
    </ul>

    <section class="prose-lazy mt-10">
      <h2>Developer utilities that keep secrets local</h2>
      <p>These are the small, sharp tools you reach for a dozen times a day: Base64 and URL encoding, JSON and other formatters, hashes (SHA family via the browser's Web Crypto), JWT decoding, regex testing, an exact LLM <strong>token counter</strong>, and Ethereum helpers (BigInt-exact wei⇄ether, Keccak-256, EIP-55 checksums). Each does one job cleanly and shows its working.</p>
      <p>Crucially, they run entirely in your browser — so pasting an API key, a private JWT, a config file or a wallet address never sends it to a server. That's the difference between a convenient tool and a liability: your secrets stay on your machine, and the tools keep working offline.</p>
    </section>

    <FaqSection faqs={faqs} />
  </div>
</Base>
