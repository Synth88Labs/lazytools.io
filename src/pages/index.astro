---
import Base from '../layouts/Base.astro';
import FaqSection from '../components/FaqSection.astro';
import { CATEGORIES, SITE } from '../lib/site';
import { popularPairsGlobal, titleNoun } from '../data/units';
import { faqSchema } from '../lib/schema';

const popularPairs = popularPairsGlobal(4);
const live = CATEGORIES.filter((c) => c.status === 'live');
const soon = CATEGORIES.filter((c) => c.status === 'coming-soon');

const faqs = [
  { q: 'Are LazyTools really free?', a: 'Yes — every tool is completely free, with no sign-up, no account, no trial, no usage limits and no paywalled features. There\'s nothing to install either; each tool opens instantly in your browser.' },
  { q: 'Do my files or data get uploaded to a server?', a: 'No. Every tool runs entirely in your browser using JavaScript and WebAssembly, so the files you open and the values you type are processed on your own device and never sent anywhere. You can prove it: open your browser\'s network tab and watch, or switch off your internet connection mid-use — the tools keep working.' },
  { q: 'Does LazyTools track me or use cookies?', a: 'No. There is no analytics, no tracking pixel and no cookies — nothing to consent to. The only optional data is an anonymous star rating you can choose to leave on a tool (just the tool name and star value, with no IP address, cookie or identifier).' },
  { q: 'Do the tools work offline?', a: 'Yes. Because the processing happens in your browser, most tools keep working with no internet connection once the page has loaded — handy on a plane or with a patchy signal.' },
  { q: 'How many tools are there, and what kinds?', a: 'Over 630 tools across 39 categories — unit and size converters, everyday and financial calculators, exact math, chemistry, physics, biology and statistics, cooking, automotive, fitness, pet, gardening, music, weather, astronomy, photography and electronics calculators, travel and trip planners, 3D-printing, solar/off-grid energy and homebrewing calculators, developer utilities, text and color tools, generators, PDF and image tools, and a passport/visa photo maker.' },
  { q: 'How accurate are the calculators?', a: 'They\'re built for exactness — using precise NIST/BIPM conversion factors, published scientific and engineering formulas, and BigInt or exact-fraction math where rounding would otherwise creep in. Many categories were checked against authoritative sources (NASA, NOAA, USDA, King Arthur Baking and others), and the harder libraries are unit-tested.' },
  { q: 'Do I need to create an account?', a: 'Never. LazyTools has no accounts and holds no personal data — you just open a tool and use it. Some tools optionally remember your preferences in your browser\'s own local storage, which stays on your device.' },
  { q: 'Is LazyTools open source?', a: 'Yes — the site is open source on GitHub, so you can read exactly how every tool works and verify the privacy claims for yourself. It\'s a project of Synth88 Labs.' },
];

/** Flagship tools across categories — hand-picked, highest-intent entries. */
const flagship = [
  { icon: '🪪', name: 'Passport Photo Maker', url: '/photo/' },
  { icon: '📶', name: 'WiFi QR Code Generator', url: '/generate/wifi-qr-code-generator/' },
  { icon: '👻', name: 'Invisible Character Detector', url: '/text/invisible-character-detector/' },
  { icon: '🧬', name: 'DNA Reverse Complement', url: '/biology/reverse-complement/' },
  { icon: '🔑', name: 'Password Generator', url: '/generate/password-generator/' },
  { icon: '🧷', name: 'Merge PDF Files', url: '/pdf/merge-pdf/' },
  { icon: '🗜️', name: 'Image Compressor', url: '/image/image-compressor/' },
  { icon: '🔢', name: 'Word Counter', url: '/text/word-counter/' },
  { icon: '📱', name: 'QR Code Generator', url: '/generate/qr-code-generator/' },
  { icon: '🔔', name: 'Normal Distribution Calculator', url: '/statistics/normal-distribution-calculator/' },
  { icon: '🎛️', name: 'OKLCH Color Picker', url: '/color/oklch-color-picker/' },
  { icon: '🧪', name: 'Interactive Periodic Table', url: '/chemistry/periodic-table/' },
  { icon: '⚗️', name: 'Chemical Equation Balancer', url: '/chemistry/chemical-equation-balancer/' },
  { icon: '🎯', name: 'Projectile Motion Calculator', url: '/physics/projectile-motion-calculator/' },
  { icon: '🎨', name: 'Paint Calculator', url: '/home/paint-calculator/' },
  { icon: '⚖️', name: 'Grams to Cups Converter', url: '/cooking/grams-to-cups-converter/' },
  { icon: '🛞', name: 'Tire Size Calculator', url: '/automotive/tire-size-calculator/' },
  { icon: '🏃', name: 'Running Pace Calculator', url: '/fitness/running-pace-calculator/' },
  { icon: '🐕', name: 'Dog Age Calculator', url: '/pets/dog-age-calculator/' },
  { icon: '🌱', name: 'Plant Spacing Calculator', url: '/garden/plant-spacing-calculator/' },
  { icon: '🎵', name: 'Note Frequency Calculator', url: '/music/note-frequency-calculator/' },
  { icon: '🥵', name: 'Heat Index Calculator', url: '/weather/heat-index-calculator/' },
  { icon: '🌙', name: 'Moon Phase Calculator', url: '/astronomy/moon-phase-calculator/' },
  { icon: '🎞️', name: 'Depth of Field Calculator', url: '/photography/depth-of-field-calculator/' },
  { icon: '🎨', name: 'Resistor Color Code Calculator', url: '/electronics/resistor-color-code-calculator/' },
  { icon: '🛫', name: 'Flight Distance Calculator', url: '/travel/flight-distance-calculator/' },
  { icon: '🧵', name: 'Filament Weight & Length Calculator', url: '/3d-printing/filament-calculator/' },
  { icon: '☀️', name: 'Solar Panel Output Calculator', url: '/solar/solar-panel-output-calculator/' },
  { icon: '🍺', name: 'ABV Calculator', url: '/brewing/abv-calculator/' },
  { icon: '🔑', name: 'Home Affordability Calculator', url: '/finance/home-affordability-calculator/' },
  { icon: '💵', name: 'Compound Interest Calculator', url: '/finance/compound-interest-calculator/' },
  { icon: '❄️', name: 'Debt Payoff Calculator', url: '/finance/debt-payoff-calculator/' },
  { icon: '％', name: 'Percentage Calculator', url: '/calc/percentage-calculator/' },
];
---

<Base
  title="LazyTools — Free Online Tools That Never Upload Your Data"
  description="630+ free, privacy-first online tools across 39 categories: unit converters, calculators, finance, exact math, chemistry & physics, cooking, automotive, fitness, pets, gardening, music, weather, astronomy, photography & electronics calculators, travel & trip planners, 3D-printing, solar/off-grid energy & homebrewing calculators, biology & lab tools, passport & visa photo makers, text-forensics and developer utilities, QR & barcode generators, PDF and image tools, and more. Everything runs in your browser — your files and inputs are never uploaded, with no analytics, cookies or tracking. No sign-up, no limits."
  schema={[faqSchema(faqs)]}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-5xl px-4 py-14 text-center sm:py-20">
      <h1 class="mx-auto max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Free online tools that <span class="text-brand-600">never upload</span> your data
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600">
        Every LazyTools utility runs entirely in your browser. No uploads, no accounts, no tracking your
        content — open a tool and it even works offline. Private by architecture, not by promise.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/tools/"
          class="rounded-xl bg-brand-700 px-6 py-3 font-semibold text-white shadow-sm transition hover:bg-brand-800"
        >
          Browse 630+ free tools
        </a>
        <a
          href="/how-it-works/"
          class="rounded-xl border border-slate-300 bg-white px-6 py-3 font-semibold text-slate-700 transition hover:border-brand-400 hover:text-brand-700"
        >
          How privacy works here
        </a>
      </div>
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm font-medium text-slate-500">
        <li>🔒 100% in-browser processing</li>
        <li>🚫 No sign-up, no file limits</li>
        <li>📴 Works offline</li>
        <li>🆓 Free forever</li>
      </ul>
    </div>
  </section>

  <!-- Categories -->
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h2 class="text-2xl font-bold text-slate-900">Tool categories</h2>
    <ul class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {live.map((c) => (
        <li>
          <a
            href={`/${c.slug}/`}
            class="flex h-full flex-col rounded-xl border-2 border-brand-200 bg-brand-50/50 p-4 transition hover:border-brand-400 hover:shadow-sm"
          >
            <span class="text-2xl" aria-hidden="true">{c.icon}</span>
            <span class="mt-2 font-semibold text-slate-900">{c.name}</span>
            <span class="mt-1 text-sm text-slate-600">{c.description}</span>
          </a>
        </li>
      ))}
      {soon.map((c) => (
        <li>
          <div class="flex h-full flex-col rounded-xl border border-slate-200 p-4 opacity-70">
            <span class="text-2xl grayscale" aria-hidden="true">{c.icon}</span>
            <span class="mt-2 font-semibold text-slate-700">{c.name}</span>
            <span class="mt-1 text-sm text-slate-500">{c.description}</span>
            <span class="mt-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Coming soon</span>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- Popular tools -->
  <section class="mx-auto max-w-5xl px-4 py-6">
    <h2 class="text-2xl font-bold text-slate-900">Popular right now</h2>
    <ul class="mt-5 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
      {flagship.map((t) => (
        <li>
          <a
            href={t.url}
            class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700"
          >
            {t.icon} {t.name}
          </a>
        </li>
      ))}
      {popularPairs.map((p) => (
        <li>
          <a
            href={`/units/${p.slug}/`}
            class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700"
          >
            {p.quantity.icon} {titleNoun(p.from)} → {titleNoun(p.to)}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Privacy pitch -->
  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="rounded-2xl bg-slate-900 px-6 py-10 text-center sm:px-12">
      <h2 class="text-2xl font-bold text-white">Why "runs in your browser" matters</h2>
      <p class="mx-auto mt-3 max-w-2xl leading-relaxed text-slate-300">
        Most "free online tools" upload your files to their servers, process them there, and promise to delete
        them later. {SITE.name} is built differently: the processing code downloads to <em>your</em> device and
        runs there. There is no server to upload to — you can verify it yourself in your browser's network tab,
        or by switching off your internet connection mid-use.
      </p>
      <a
        href="/how-it-works/"
        class="mt-6 inline-block rounded-xl bg-white px-6 py-3 font-semibold text-slate-900 transition hover:bg-slate-100"
      >
        See the technical details
      </a>
    </div>
  </section>

  <!-- What you can do -->
  <section class="mx-auto max-w-5xl px-4 pb-4">
    <h2 class="text-2xl font-bold text-slate-900">One toolbox for the whole day</h2>
    <div class="mt-4 grid gap-4 text-sm leading-relaxed text-slate-600 sm:grid-cols-2 lg:grid-cols-3">
      <p><strong class="text-slate-900">Convert anything.</strong> Length, weight, temperature, volume, data and hundreds more unit pairs with exact NIST/BIPM factors — plus ring, shoe and clothing sizes across US, UK and EU systems.</p>
      <p><strong class="text-slate-900">Do the math, exactly.</strong> Percentages, loans and mortgages, fractions with steps, primes, quadratics, statistics and BigInt-scale arithmetic that never silently rounds.</p>
      <p><strong class="text-slate-900">Run the lab.</strong> Balance chemical equations, compute molar mass, solve SUVAT and Ohm's law, and work through biology and statistics — each showing the working, not just an answer.</p>
      <p><strong class="text-slate-900">Handle everyday life.</strong> Plan finances, scale a recipe, size a tire, pace a run, tell your dog's age in human years, space a garden bed, tune an instrument or read the weather's "feels like."</p>
      <p><strong class="text-slate-900">Work with files, privately.</strong> Merge and split PDFs, compress and convert images, clean metadata, and make passport & visa photos for 80+ countries — all without an upload.</p>
      <p><strong class="text-slate-900">Build and inspect.</strong> Format and encode data, hash and check text, generate QR codes, passwords and UUIDs, and detect invisible characters or AI watermarks in text.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-5xl px-4 pb-12">
    <FaqSection faqs={faqs} />
  </section>
</Base>
