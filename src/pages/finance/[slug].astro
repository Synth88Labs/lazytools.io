---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import CompoundInterestTool from '../../components/finance/CompoundInterestTool.tsx';
import LiquidityRatiosTool from '../../components/finance/LiquidityRatiosTool.tsx';
import LeverageRatiosTool from '../../components/finance/LeverageRatiosTool.tsx';
import CoverageRatiosTool from '../../components/finance/CoverageRatiosTool.tsx';
import ProfitabilityRatiosTool from '../../components/finance/ProfitabilityRatiosTool.tsx';
import EfficiencyRatiosTool from '../../components/finance/EfficiencyRatiosTool.tsx';
import ValuationRatiosTool from '../../components/finance/ValuationRatiosTool.tsx';
import AffordabilityTool from '../../components/finance/AffordabilityTool.tsx';
import RetirementTool from '../../components/finance/RetirementTool.tsx';
import BudgetTool from '../../components/finance/BudgetTool.tsx';
import DebtToIncomeTool from '../../components/finance/DebtToIncomeTool.tsx';
import InflationTool from '../../components/finance/InflationTool.tsx';
import NpvIrrTool from '../../components/finance/NpvIrrTool.tsx';
import DebtPayoffTool from '../../components/finance/DebtPayoffTool.tsx';
import SavingsGoalTool from '../../components/finance/SavingsGoalTool.tsx';
import LoanPayoffTool from '../../components/finance/LoanPayoffTool.tsx';
import CreditCardPayoffTool from '../../components/finance/CreditCardPayoffTool.tsx';
import CagrTool from '../../components/finance/CagrTool.tsx';
import Rule72Tool from '../../components/finance/Rule72Tool.tsx';
import RoiTool from '../../components/finance/RoiTool.tsx';
import BreakEvenTool from '../../components/finance/BreakEvenTool.tsx';
import AprApyTool from '../../components/finance/AprApyTool.tsx';
import { FIN_TOOLS, type FinanceToolDef } from '../../data/finance/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return FIN_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: FinanceToolDef = FIN_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: tool.name, url: `/finance/${tool.slug}/` },
];

const related = FIN_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/finance/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/finance/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`finance/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'compound' && <CompoundInterestTool client:load />}
      {tool.widget === 'debt' && <DebtPayoffTool client:load />}
      {tool.widget === 'savings' && <SavingsGoalTool client:load />}
      {tool.widget === 'loan' && <LoanPayoffTool client:load />}
      {tool.widget === 'creditcard' && <CreditCardPayoffTool client:load />}
      {tool.widget === 'cagr' && <CagrTool client:load />}
      {tool.widget === 'rule72' && <Rule72Tool client:load />}
      {tool.widget === 'roi' && <RoiTool client:load />}
      {tool.widget === 'breakeven' && <BreakEvenTool client:load />}
      {tool.widget === 'aprapy' && <AprApyTool client:load />}
      {tool.widget === 'liquidityratios' && <LiquidityRatiosTool client:load />}
      {tool.widget === 'leverageratios' && <LeverageRatiosTool client:load />}
      {tool.widget === 'coverageratios' && <CoverageRatiosTool client:load />}
      {tool.widget === 'profitabilityratios' && <ProfitabilityRatiosTool client:load />}
      {tool.widget === 'efficiencyratios' && <EfficiencyRatiosTool client:load />}
      {tool.widget === 'valuationratios' && <ValuationRatiosTool client:load />}
      {tool.widget === 'affordability' && <AffordabilityTool client:load />}
      {tool.widget === 'retirement' && <RetirementTool client:load />}
      {tool.widget === 'budget' && <BudgetTool client:load />}
      {tool.widget === 'dti' && <DebtToIncomeTool client:load />}
      {tool.widget === 'inflation' && <InflationTool client:load />}
      {tool.widget === 'npvirr' && <NpvIrrTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`finance/${tool.slug}`}
        avg={ratingFor(`finance/${tool.slug}`)?.avg}
        count={ratingFor(`finance/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <p class="mt-8 rounded-xl border border-slate-200 bg-slate-50 p-4 text-xs text-slate-500">
      <strong class="text-slate-600">Educational information, not financial advice.</strong> These
      calculators use standard formulas with the figures you enter; results are illustrations, not
      guarantees. For decisions about your money, consult a qualified, regulated financial professional.
    </p>

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related finance tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/finance/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/finance/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All finance tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
