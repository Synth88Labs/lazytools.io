---
import Base from '../layouts/Base.astro';
import { popularPairsGlobal, titleNoun } from '../data/units';
import { CATEGORIES } from '../lib/site';

const popular = popularPairsGlobal(6);
const live = CATEGORIES.filter((c) => c.status === 'live');
---

<Base
  title="Page Not Found (404) | LazyTools"
  description="This page doesn't exist. Browse our free, privacy-first online tools instead."
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-4 py-16 text-center">
    <p class="text-6xl" aria-hidden="true">🦥</p>
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900">Page not found</h1>
    <p class="mt-3 text-lg text-slate-600">
      Even a lazy sloth couldn't find this page. It may have moved — but every tool is one click away.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-xl bg-brand-700 px-6 py-3 font-semibold text-white hover:bg-brand-800">Go home</a>
      <a href="/tools/" class="rounded-xl border border-slate-300 px-6 py-3 font-semibold text-slate-700 hover:border-brand-400">Browse all tools</a>
    </div>
    <h2 class="mt-12 text-lg font-semibold text-slate-900">Popular tools</h2>
    <ul class="mt-4 grid gap-2 text-left sm:grid-cols-2">
      {live.map((c) => (
        <li>
          <a href={`/${c.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 hover:border-brand-400 hover:text-brand-700">
            {c.icon} {c.name}
          </a>
        </li>
      ))}
      {popular.map((p) => (
        <li>
          <a href={`/units/${p.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 hover:border-brand-400 hover:text-brand-700">
            {p.quantity.icon} {titleNoun(p.from)} → {titleNoun(p.to)}
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>
