---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import NoteFrequencyTool from '../../components/music/NoteFrequencyTool.tsx';
import BpmDelayTool from '../../components/music/BpmDelayTool.tsx';
import TapTempoTool from '../../components/music/TapTempoTool.tsx';
import MetronomeTool from '../../components/music/MetronomeTool.tsx';
import IntervalTool from '../../components/music/IntervalTool.tsx';
import TransposeTool from '../../components/music/TransposeTool.tsx';
import AudioFileSizeTool from '../../components/music/AudioFileSizeTool.tsx';
import TimeSignatureTool from '../../components/music/TimeSignatureTool.tsx';
import ChordScaleTool from '../../components/music/ChordScaleTool.tsx';
import BufferLatencyTool from '../../components/music/BufferLatencyTool.tsx';
import KeySignatureTool from '../../components/music/KeySignatureTool.tsx';
import SampleRateTool from '../../components/music/SampleRateTool.tsx';
import ReverbTool from '../../components/music/ReverbTool.tsx';
import { MUSIC_TOOLS, type MusicToolDef } from '../../data/music/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return MUSIC_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: MusicToolDef = MUSIC_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Music & Audio', url: '/music/' },
  { name: tool.name, url: `/music/${tool.slug}/` },
];

const related = MUSIC_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/music/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/music/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`music/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'notefreq' && <NoteFrequencyTool client:load />}
      {tool.widget === 'delay' && <BpmDelayTool client:load />}
      {tool.widget === 'tap' && <TapTempoTool client:load />}
      {tool.widget === 'metronome' && <MetronomeTool client:load />}
      {tool.widget === 'interval' && <IntervalTool client:load />}
      {tool.widget === 'transpose' && <TransposeTool client:load />}
      {tool.widget === 'filesize' && <AudioFileSizeTool client:load />}
      {tool.widget === 'timesig' && <TimeSignatureTool client:load />}
      {tool.widget === 'chordscale' && <ChordScaleTool client:load />}
      {tool.widget === 'bufferlatency' && <BufferLatencyTool client:load />}
      {tool.widget === 'keysig' && <KeySignatureTool client:load />}
      {tool.widget === 'samplerate' && <SampleRateTool client:load />}
      {tool.widget === 'reverb' && <ReverbTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`music/${tool.slug}`}
        avg={ratingFor(`music/${tool.slug}`)?.avg}
        count={ratingFor(`music/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related music tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/music/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/music/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All music tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
