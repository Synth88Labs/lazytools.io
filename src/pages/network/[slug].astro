---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import SubnetCalculatorTool from '../../components/network/SubnetCalculatorTool.tsx';
import Ipv6SubnetTool from '../../components/network/Ipv6SubnetTool.tsx';
import CidrRangeTool from '../../components/network/CidrRangeTool.tsx';
import IpConverterTool from '../../components/network/IpConverterTool.tsx';
import Ipv6FormatTool from '../../components/network/Ipv6FormatTool.tsx';
import ChmodCalculatorTool from '../../components/network/ChmodCalculatorTool.tsx';
import CronParserTool from '../../components/network/CronParserTool.tsx';
import MacFormatterTool from '../../components/network/MacFormatterTool.tsx';
import DownloadTimeTool from '../../components/network/DownloadTimeTool.tsx';
import BandwidthConverterTool from '../../components/network/BandwidthConverterTool.tsx';
import { NETWORK_TOOLS, type NetworkToolDef } from '../../data/network/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return NETWORK_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: NetworkToolDef = NETWORK_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Network & IT', url: '/network/' },
  { name: tool.name, url: `/network/${tool.slug}/` },
];

const related = NETWORK_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/network/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/network/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`network/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'subnet' && <SubnetCalculatorTool client:load />}
      {tool.widget === 'ipv6-subnet' && <Ipv6SubnetTool client:load />}
      {tool.widget === 'cidr-range' && <CidrRangeTool client:load />}
      {tool.widget === 'ip-converter' && <IpConverterTool client:load />}
      {tool.widget === 'ipv6-format' && <Ipv6FormatTool client:load />}
      {tool.widget === 'chmod' && <ChmodCalculatorTool client:load />}
      {tool.widget === 'cron' && <CronParserTool client:load />}
      {tool.widget === 'mac' && <MacFormatterTool client:load />}
      {tool.widget === 'downloadtime' && <DownloadTimeTool client:load />}
      {tool.widget === 'bandwidth' && <BandwidthConverterTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`network/${tool.slug}`}
        avg={ratingFor(`network/${tool.slug}`)?.avg}
        count={ratingFor(`network/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related network tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/network/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/network/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All network & IT tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
