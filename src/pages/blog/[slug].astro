---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqSection from '../../components/FaqSection.astro';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';
import { allPairs, titleNoun } from '../../data/units';

/** Human label for a tool CTA, e.g. "Kilograms → Pounds converter" */
function toolLabel(url: string): string {
  const slug = url.split('/').filter(Boolean).pop() ?? '';
  const pair = allPairs().find((p) => p.slug === slug);
  if (pair) return `${titleNoun(pair.from)} → ${titleNoun(pair.to)} converter`;
  return slug
    .split('-')
    .map((w) => (w.length <= 3 ? w.toUpperCase() : w.charAt(0).toUpperCase() + w.slice(1)))
    .join(' ');
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Table of contents from H2s (H3s nest under them)
const toc = headings.filter((h) => h.depth === 2);

// Reading time: ~220 wpm on the raw markdown body
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingMinutes = Math.max(1, Math.round(words / 220));

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: post.data.title, url: `/blog/${post.id}/` },
];

const dateFmt = (d: Date) => d.toISOString().slice(0, 10);

const schema: Record<string, unknown>[] = [
  breadcrumbSchema(crumbs),
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    ...(post.data.heroImage ? { image: new URL(post.data.heroImage, SITE.url).href } : {}),
    datePublished: dateFmt(post.data.pubDate),
    dateModified: dateFmt(post.data.updatedDate ?? post.data.pubDate),
    url: `${SITE.url}/blog/${post.id}/`,
    wordCount: words,
    keywords: post.data.keywords.join(', '),
    publisher: { '@type': 'Organization', name: SITE.parent.name, url: SITE.parent.url },
    author: { '@type': 'Organization', name: SITE.name, url: SITE.url },
    isPartOf: { '@type': 'Blog', name: `${SITE.name} Blog`, url: `${SITE.url}/blog/` },
  },
];
if (post.data.faqs.length > 0) schema.push(faqSchema(post.data.faqs));
---

<Base
  title={`${post.data.title} | LazyTools Blog`}
  description={post.data.description}
  schema={schema}
  noindex={post.data.draft}
  image={post.data.heroImage}
>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.archetype}</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{post.data.title}</h1>
      <p class="mt-3 text-sm text-slate-500">
        By <a href="/about/" class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-2 hover:text-brand-700">the LazyTools team</a>
        · Published {dateFmt(post.data.pubDate)}
        {post.data.updatedDate && <> · Updated {dateFmt(post.data.updatedDate)}</>}
        · {readingMinutes} min read
        {post.data.draft && (
          <span class="ml-2 rounded bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800">DRAFT — not indexed</span>
        )}
      </p>
    </header>

    {
      post.data.heroImage && (
        <img
          src={post.data.heroImage}
          alt={post.data.heroAlt ?? post.data.title}
          width="1200"
          height="630"
          class="mt-6 w-full rounded-2xl border border-slate-200"
        />
      )
    }

    {
      toc.length > 2 && (
        <nav aria-label="Table of contents" class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
          <p class="text-sm font-bold uppercase tracking-wide text-slate-900">On this page</p>
          <ol class="mt-3 grid gap-1.5 text-sm sm:grid-cols-2">
            {toc.map((h, i) => (
              <li>
                <a href={`#${h.slug}`} class="flex gap-2 text-slate-600 hover:text-brand-700 hover:underline">
                  <span class="font-semibold text-brand-700">{i + 1}.</span>
                  {h.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="prose-lazy mt-8">
      <Content />
    </div>

    {post.data.faqs.length > 0 && <FaqSection faqs={post.data.faqs} />}

    <aside class="mt-10 rounded-xl border border-brand-200 bg-brand-50 p-5">
      <p class="font-semibold text-slate-900">Try it yourself — free, instant, and nothing gets uploaded:</p>
      <ul class="mt-3 flex flex-wrap gap-2">
        {post.data.tools.map((t) => (
          <li>
            <a
              href={t}
              class="inline-block rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-800"
            >
              {toolLabel(t)} →
            </a>
          </li>
        ))}
      </ul>
    </aside>
  </article>
</Base>
