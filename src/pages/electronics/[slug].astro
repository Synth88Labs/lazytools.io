---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import ResistorColorTool from '../../components/electronics/ResistorColorTool.tsx';
import LedResistorTool from '../../components/electronics/LedResistorTool.tsx';
import VoltageDividerTool from '../../components/electronics/VoltageDividerTool.tsx';
import CapacitorCodeTool from '../../components/electronics/CapacitorCodeTool.tsx';
import WireGaugeTool from '../../components/electronics/WireGaugeTool.tsx';
import RcFilterTool from '../../components/electronics/RcFilterTool.tsx';
import Timer555Tool from '../../components/electronics/Timer555Tool.tsx';
import BatteryLifeTool from '../../components/electronics/BatteryLifeTool.tsx';
import SmdResistorTool from '../../components/electronics/SmdResistorTool.tsx';
import LcResonanceTool from '../../components/electronics/LcResonanceTool.tsx';
import SeriesParallelResistanceTool from '../../components/electronics/SeriesParallelResistanceTool.tsx';
import SeriesParallelCapacitanceTool from '../../components/electronics/SeriesParallelCapacitanceTool.tsx';
import OhmsLawTool from '../../components/electronics/OhmsLawTool.tsx';
import ReactanceTool from '../../components/electronics/ReactanceTool.tsx';
import DecibelTool from '../../components/electronics/DecibelTool.tsx';
import { ELECTRONICS_TOOLS, type ElectronicsToolDef } from '../../data/electronics/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return ELECTRONICS_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: ElectronicsToolDef = ELECTRONICS_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Electronics & Circuits', url: '/electronics/' },
  { name: tool.name, url: `/electronics/${tool.slug}/` },
];

const related = ELECTRONICS_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/electronics/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/electronics/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`electronics/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'resistor' && <ResistorColorTool client:load />}
      {tool.widget === 'led' && <LedResistorTool client:load />}
      {tool.widget === 'divider' && <VoltageDividerTool client:load />}
      {tool.widget === 'capcode' && <CapacitorCodeTool client:load />}
      {tool.widget === 'awg' && <WireGaugeTool client:load />}
      {tool.widget === 'rc' && <RcFilterTool client:load />}
      {tool.widget === 'timer555' && <Timer555Tool client:load />}
      {tool.widget === 'battery' && <BatteryLifeTool client:load />}
      {tool.widget === 'smd' && <SmdResistorTool client:load />}
      {tool.widget === 'lc' && <LcResonanceTool client:load />}
      {tool.widget === 'sp-res' && <SeriesParallelResistanceTool client:load />}
      {tool.widget === 'sp-cap' && <SeriesParallelCapacitanceTool client:load />}
      {tool.widget === 'ohmslaw' && <OhmsLawTool client:load />}
      {tool.widget === 'reactance' && <ReactanceTool client:load />}
      {tool.widget === 'decibel' && <DecibelTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`electronics/${tool.slug}`}
        avg={ratingFor(`electronics/${tool.slug}`)?.avg}
        count={ratingFor(`electronics/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related electronics tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/electronics/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/electronics/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All electronics tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
