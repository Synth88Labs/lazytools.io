---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import FilamentTool from '../../components/printing3d/FilamentTool.tsx';
import FilamentCostTool from '../../components/printing3d/FilamentCostTool.tsx';
import PrintEnergyTool from '../../components/printing3d/PrintEnergyTool.tsx';
import ScaleTool from '../../components/printing3d/ScaleTool.tsx';
import EstepsTool from '../../components/printing3d/EstepsTool.tsx';
import FlowTool from '../../components/printing3d/FlowTool.tsx';
import VolumetricFlowTool from '../../components/printing3d/VolumetricFlowTool.tsx';
import ResinTool from '../../components/printing3d/ResinTool.tsx';
import { PRINTING3D_TOOLS, type Printing3dToolDef } from '../../data/printing3d/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return PRINTING3D_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: Printing3dToolDef = PRINTING3D_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: '3D Printing', url: '/3d-printing/' },
  { name: tool.name, url: `/3d-printing/${tool.slug}/` },
];

const related = PRINTING3D_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/3d-printing/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/3d-printing/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`3d-printing/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'filament' && <FilamentTool client:load />}
      {tool.widget === 'cost' && <FilamentCostTool client:load />}
      {tool.widget === 'energy' && <PrintEnergyTool client:load />}
      {tool.widget === 'scale' && <ScaleTool client:load />}
      {tool.widget === 'esteps' && <EstepsTool client:load />}
      {tool.widget === 'flow' && <FlowTool client:load />}
      {tool.widget === 'volflow' && <VolumetricFlowTool client:load />}
      {tool.widget === 'resin' && <ResinTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`3d-printing/${tool.slug}`}
        avg={ratingFor(`3d-printing/${tool.slug}`)?.avg}
        count={ratingFor(`3d-printing/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related 3D printing tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/3d-printing/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/3d-printing/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All 3D printing tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
