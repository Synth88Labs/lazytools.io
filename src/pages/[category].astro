---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { CATEGORIES } from '../lib/site';

export function getStaticPaths() {
  return CATEGORIES.filter((c) => c.status === 'coming-soon').map((c) => ({
    params: { category: c.slug },
    props: { slug: c.slug },
  }));
}

const { slug } = Astro.props;
const category = CATEGORIES.find((c) => c.slug === slug)!;
const crumbs = [
  { name: 'Home', url: '/' },
  { name: category.name, url: `/${category.slug}/` },
];
---

<Base
  title={`${category.name} — Coming Soon | LazyTools`}
  description={`${category.description} Coming soon to LazyTools — free and 100% in your browser.`}
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <div class="mt-10 rounded-2xl border border-slate-200 p-10 text-center">
      <span class="text-5xl" aria-hidden="true">{category.icon}</span>
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900">{category.name}</h1>
      <p class="mx-auto mt-3 max-w-md text-lg text-slate-600">{category.description}</p>
      <p class="mt-6 inline-block rounded-full bg-brand-50 px-4 py-1.5 text-sm font-semibold text-brand-700">
        🚧 Coming soon — private and free, like everything here
      </p>
      <p class="mt-8 text-sm text-slate-500">
        In the meantime, try our <a href="/units/" class="font-medium text-brand-700 underline">unit converters</a>
        or browse <a href="/tools/" class="font-medium text-brand-700 underline">all tools</a>.
      </p>
    </div>
  </div>
</Base>
