---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import PomodoroTool from '../../components/productivity/PomodoroTool.tsx';
import CountdownTool from '../../components/productivity/CountdownTool.tsx';
import MeetingCostTool from '../../components/productivity/MeetingCostTool.tsx';
import EisenhowerTool from '../../components/productivity/EisenhowerTool.tsx';
import HabitTrackerTool from '../../components/productivity/HabitTrackerTool.tsx';
import KanbanTool from '../../components/productivity/KanbanTool.tsx';
import MindMapTool from '../../components/productivity/MindMapTool.tsx';
import GanttTool from '../../components/productivity/GanttTool.tsx';
import DecisionMatrixTool from '../../components/productivity/DecisionMatrixTool.tsx';
import RiceTool from '../../components/productivity/RiceTool.tsx';
import SwotTool from '../../components/productivity/SwotTool.tsx';
import ProsConsTool from '../../components/productivity/ProsConsTool.tsx';
import FlowchartTool from '../../components/productivity/FlowchartTool.tsx';
import SwimlaneTool from '../../components/productivity/SwimlaneTool.tsx';
import WhiteboardTool from '../../components/productivity/WhiteboardTool.tsx';
import TimeBlockingTool from '../../components/productivity/TimeBlockingTool.tsx';
import OkrTool from '../../components/productivity/OkrTool.tsx';
import ChecklistTool from '../../components/productivity/ChecklistTool.tsx';
import RetroTool from '../../components/productivity/RetroTool.tsx';
import EyeRestTool from '../../components/productivity/EyeRestTool.tsx';
import { PRODUCTIVITY_TOOLS, type ProductivityToolDef } from '../../data/productivity/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return PRODUCTIVITY_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: ProductivityToolDef = PRODUCTIVITY_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Productivity', url: '/productivity/' },
  { name: tool.name, url: `/productivity/${tool.slug}/` },
];

const related = PRODUCTIVITY_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/productivity/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/productivity/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`productivity/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'pomodoro' && <PomodoroTool client:load />}
      {tool.widget === 'countdown' && <CountdownTool client:load />}
      {tool.widget === 'meeting-cost' && <MeetingCostTool client:load />}
      {tool.widget === 'eisenhower' && <EisenhowerTool client:load />}
      {tool.widget === 'habit' && <HabitTrackerTool client:load />}
      {tool.widget === 'kanban' && <KanbanTool client:load />}
      {tool.widget === 'mindmap' && <MindMapTool client:load />}
      {tool.widget === 'gantt' && <GanttTool client:load />}
      {tool.widget === 'decision-matrix' && <DecisionMatrixTool client:load />}
      {tool.widget === 'rice' && <RiceTool client:load />}
      {tool.widget === 'swot' && <SwotTool client:load />}
      {tool.widget === 'pros-cons' && <ProsConsTool client:load />}
      {tool.widget === 'flowchart' && <FlowchartTool client:load />}
      {tool.widget === 'swimlane' && <SwimlaneTool client:load />}
      {tool.widget === 'whiteboard' && <WhiteboardTool client:load />}
      {tool.widget === 'time-blocking' && <TimeBlockingTool client:load />}
      {tool.widget === 'okr' && <OkrTool client:load />}
      {tool.widget === 'checklist' && <ChecklistTool client:load />}
      {tool.widget === 'retro' && <RetroTool client:load />}
      {tool.widget === 'eye-rest' && <EyeRestTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`productivity/${tool.slug}`}
        avg={ratingFor(`productivity/${tool.slug}`)?.avg}
        count={ratingFor(`productivity/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related productivity tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/productivity/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/productivity/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All productivity tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
