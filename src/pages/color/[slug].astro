---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import ColorConverterTool from '../../components/color/ColorConverterTool.tsx';
import HsvConverterTool from '../../components/color/HsvConverterTool.tsx';
import DeltaETool from '../../components/color/DeltaETool.tsx';
import ColorTempTool from '../../components/color/ColorTempTool.tsx';
import ContrastCheckerTool from '../../components/color/ContrastCheckerTool.tsx';
import ShadesTool from '../../components/color/ShadesTool.tsx';
import GradientTool from '../../components/color/GradientTool.tsx';
import MixerTool from '../../components/color/MixerTool.tsx';
import BrandColorsTool from '../../components/color/BrandColorsTool.tsx';
import OklchTool from '../../components/color/OklchTool.tsx';
import AccessibleColorTool from '../../components/color/AccessibleColorTool.tsx';
import ApcaTool from '../../components/color/ApcaTool.tsx';
import ContrastGridTool from '../../components/color/ContrastGridTool.tsx';
import CvdTool from '../../components/color/CvdTool.tsx';
import HarmonyTool from '../../components/color/HarmonyTool.tsx';
import ImagePickerTool from '../../components/color/ImagePickerTool.tsx';
import ColorNameTool from '../../components/color/ColorNameTool.tsx';
import OklchScaleTool from '../../components/color/OklchScaleTool.tsx';
import { COLOR_TOOLS, type ColorToolDef } from '../../data/color/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return COLOR_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: ColorToolDef = COLOR_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Color Tools', url: '/color/' },
  { name: tool.name, url: `/color/${tool.slug}/` },
];

const related = COLOR_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/color/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/color/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`color/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'converter' && <ColorConverterTool client:load preset={tool.presetInput ?? 'hex'} />}
      {tool.widget === 'hsv' && <HsvConverterTool client:load />}
      {tool.widget === 'deltae' && <DeltaETool client:load />}
      {tool.widget === 'colortemp' && <ColorTempTool client:load />}
      {tool.widget === 'contrast' && <ContrastCheckerTool client:load />}
      {tool.widget === 'shades' && <ShadesTool client:load />}
      {tool.widget === 'gradient' && <GradientTool client:load />}
      {tool.widget === 'mixer' && <MixerTool client:load />}
      {tool.widget === 'brands' && <BrandColorsTool client:load />}
      {tool.widget === 'oklch' && <OklchTool client:load dir={tool.oklchDir ?? 'hex-to-oklch'} />}
      {tool.widget === 'accessible' && <AccessibleColorTool client:load />}
      {tool.widget === 'apca' && <ApcaTool client:load />}
      {tool.widget === 'grid' && <ContrastGridTool client:load />}
      {tool.widget === 'cvd' && <CvdTool client:load initialType={tool.cvdType ?? 'deuteranopia'} />}
      {tool.widget === 'harmony' && <HarmonyTool client:load preset={tool.harmonyPreset ?? 'all'} />}
      {tool.widget === 'imagepicker' && <ImagePickerTool client:load />}
      {tool.widget === 'colorname' && <ColorNameTool client:load />}
      {tool.widget === 'oklchscale' && <OklchScaleTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`color/${tool.slug}`}
        avg={ratingFor(`color/${tool.slug}`)?.avg}
        count={ratingFor(`color/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related color tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/color/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/color/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All color tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
