---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import CalcWidget from '../../components/CalcWidget.tsx';
import MortgageCalc from '../../components/calc/MortgageCalc.tsx';
import GpaCalc from '../../components/calc/GpaCalc.tsx';
import RatingWidget from '../../components/RatingWidget.tsx';
import { CALCULATORS, type CalcDef } from '../../data/calc/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return CALCULATORS.map((c) => ({ params: { slug: c.slug }, props: { slug: c.slug } }));
}

const { slug } = Astro.props;
const calc: CalcDef = CALCULATORS.find((c) => c.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Calculators', url: '/calc/' },
  { name: calc.name, url: `/calc/${calc.slug}/` },
];

const pageTitle = `${calc.name} — Free & Private | LazyTools`;

const faqs = [
  ...calc.faqs,
  {
    q: `Is this ${calc.name.toLowerCase()} accurate and private?`,
    a: 'Yes. It uses the standard published formula, shows its working under every result, and computes locally in your browser — your inputs are never sent to a server, and the page works offline.',
  },
];

const related = CALCULATORS.filter((c) => c.slug !== calc.slug).slice(0, 6);

const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/calc/${calc.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: calc.name,
    url: `/calc/${calc.slug}/`,
    description: calc.description,
    rating: ratingFor(`calc/${calc.slug}`),
  }),
  faqSchema(faqs),
];
---

<Base title={pageTitle} description={calc.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {calc.icon} {calc.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{calc.lead}</strong>{' '}
      {calc.widget ? 'Everything runs instantly, entirely on your device.' : 'Enter your values below — results update instantly, entirely on your device.'}
    </p>

    <div class="mt-6">
      {calc.widget === 'mortgage' ? (
        <MortgageCalc client:load />
      ) : calc.widget === 'gpa' ? (
        <GpaCalc client:load />
      ) : (
        <CalcWidget client:load computeId={calc.computeId} fields={calc.fields} />
      )}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`calc/${calc.slug}`}
        avg={ratingFor(`calc/${calc.slug}`)?.avg}
        count={ratingFor(`calc/${calc.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {calc.name.toLowerCase()} works</h2>
      <p>{calc.formula}</p>
      <p><strong>Example:</strong> {calc.example}</p>
      {calc.note && <p>{calc.note}</p>}
    </section>

    <FaqSection faqs={faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related calculators</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a
              href={`/calc/${r.slug}/`}
              class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700"
            >
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/calc/"
            class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400"
          >
            All calculators →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id}/`}
                  class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm"
                >
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
