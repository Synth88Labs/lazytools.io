---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import { ASTRO_TOOLS } from '../../data/astronomy/index';
import { breadcrumbSchema, collectionPageSchema, faqSchema } from '../../lib/schema';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Astronomy & Space', url: '/astronomy/' },
];
const faqs = [
  { q: 'Are these astronomy calculators accurate?', a: 'Yes — they use established astronomical constants and algorithms: the synodic month for lunar phase, the NOAA solar-position algorithm for sunrise/sunset (±1 minute), NASA planetary data for gravity and orbits, and the IAU-defined light-year and parsec. Sources are cited on each tool.' },
  { q: 'Do the sunrise and moon tools use my location?', a: 'You enter your latitude, longitude and date yourself (or pick a city) — nothing is fetched or tracked. The moon phase needs only a date.' },
  { q: 'Is this real-time astronomical data?', a: 'No — these are calculators. They compute phases, times, distances and optics from the values you enter and fixed astronomical constants, not a live feed.' },
  { q: 'Is my data uploaded?', a: 'No. Every tool runs entirely in your browser — nothing is sent to a server, and they work offline.' },
];
const schema = [
  breadcrumbSchema(crumbs),
  collectionPageSchema({ name: 'Astronomy & Space Calculators', url: '/astronomy/', description: 'Free, private astronomy calculators: moon phase, sunrise & sunset, weight and age on other planets, light travel time, angular size, telescope optics and stellar parallax.', items: ASTRO_TOOLS.map((t) => ({ name: t.name, url: `/astronomy/${t.slug}/` })) }),
  faqSchema(faqs),
];
---

<Base
  title="Astronomy & Space Calculators — Moon Phase, Sunrise, Planets | LazyTools"
  description="Free astronomy calculators that run in your browser: moon phase, sunrise & sunset (NOAA algorithm), weight and age on other planets, light travel time, angular size, telescope magnification and stellar parallax. Sourced constants, no upload."
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Astronomy & Space Calculators</h1>
    <p class="mt-3 max-w-3xl text-lg leading-relaxed text-slate-700">
      Explore the sky by the numbers — find the moon phase and sunrise for any date, discover your weight and
      age across the solar system, work out light travel times and angular sizes, and size up a telescope.
      Real astronomical algorithms and NASA data, running entirely in your browser.
    </p>

    <div class="mt-5"><PrivacyStrip /></div>

    <section class="mt-8">
      <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {ASTRO_TOOLS.map((t) => (
          <li>
            <a href={`/astronomy/${t.slug}/`} class="flex h-full flex-col rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
              <span class="text-2xl" aria-hidden="true">{t.icon}</span>
              <span class="mt-2 font-semibold text-slate-900">{t.name}</span>
              <span class="mt-1 text-sm text-slate-600">{t.lead.split('—')[0].split('(')[0]}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <FaqSection faqs={faqs} />
  </div>
</Base>
