---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import SolarOutputTool from '../../components/solar/SolarOutputTool.tsx';
import OffGridLoadTool from '../../components/solar/OffGridLoadTool.tsx';
import SolarBatteryTool from '../../components/solar/SolarBatteryTool.tsx';
import InverterTool from '../../components/solar/InverterTool.tsx';
import ApplianceCostTool from '../../components/solar/ApplianceCostTool.tsx';
import PaybackTool from '../../components/solar/PaybackTool.tsx';
import VoltageDropTool from '../../components/solar/VoltageDropTool.tsx';
import ChargeTimeTool from '../../components/solar/ChargeTimeTool.tsx';
import PanelTiltTool from '../../components/solar/PanelTiltTool.tsx';
import ArrayWiringTool from '../../components/solar/ArrayWiringTool.tsx';
import { SOLAR_TOOLS, type SolarToolDef } from '../../data/solar/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return SOLAR_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: SolarToolDef = SOLAR_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Solar & Energy', url: '/solar/' },
  { name: tool.name, url: `/solar/${tool.slug}/` },
];

const related = SOLAR_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/solar/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/solar/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`solar/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'output' && <SolarOutputTool client:load />}
      {tool.widget === 'load' && <OffGridLoadTool client:load />}
      {tool.widget === 'battery' && <SolarBatteryTool client:load />}
      {tool.widget === 'inverter' && <InverterTool client:load />}
      {tool.widget === 'appliance' && <ApplianceCostTool client:load />}
      {tool.widget === 'payback' && <PaybackTool client:load />}
      {tool.widget === 'vdrop' && <VoltageDropTool client:load />}
      {tool.widget === 'charge' && <ChargeTimeTool client:load />}
      {tool.widget === 'tilt' && <PanelTiltTool client:load />}
      {tool.widget === 'array' && <ArrayWiringTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`solar/${tool.slug}`}
        avg={ratingFor(`solar/${tool.slug}`)?.avg}
        count={ratingFor(`solar/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related solar & energy tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/solar/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/solar/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All solar & energy tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
