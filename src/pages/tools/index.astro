    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🗓️ Calendars</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CALENDAR_TOOLS.map((t) => (
          <li>
            <a href={`/calendar/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
