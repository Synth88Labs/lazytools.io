  <script>
    const filter = document.getElementById('tools-filter') as HTMLInputElement | null;
    const list = document.getElementById('tools-list');
    const overview = document.getElementById('tools-overview');
    const status = document.getElementById('tools-filter-status');
    const empty = document.getElementById('tools-empty');
    if (filter && list) {
      const items = Array.from(list.querySelectorAll('li'));
      const sections = Array.from(list.querySelectorAll('section'));
      const meta = items.map((li) => {
        const section = li.closest('section');
        const h2 = section?.querySelector('h2')?.textContent ?? '';
        const div = li.closest('div');
        const block = div && div.parentElement === section && div.querySelector('h3') ? (div as HTMLElement) : null;
        const h3 = block?.querySelector('h3')?.textContent ?? '';
        return { li, block, text: `${li.textContent} ${h2} ${h3}`.toLowerCase() };
      });
      const total = items.length;
      const apply = () => {
        const q = filter.value.trim().toLowerCase();
        let visible = 0;
        for (const m of meta) {
          const show = q === '' || m.text.includes(q);
          (m.li as HTMLElement).hidden = !show;
          if (show) visible++;
        }
        for (const m of meta) {
          if (m.block) m.block.hidden = !Array.from(m.block.querySelectorAll('li')).some((x) => !(x as HTMLElement).hidden);
        }
        for (const s of sections) {
          (s as HTMLElement).hidden = !Array.from(s.querySelectorAll('li')).some((x) => !(x as HTMLElement).hidden);
        }
        if (overview) (overview as HTMLElement).hidden = q !== '';
        if (empty) (empty as HTMLElement).hidden = !(q !== '' && visible === 0);
        if (status) status.textContent = q === '' ? '' : `${visible} of ${total} tools match “${filter.value.trim()}”.`;
      };
      filter.addEventListener('input', apply);
    }
  </script>
