    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🔐 Privacy & Security</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {SECURITY_TOOLS.map((t) => (
          <li>
