        {FIN_TOOLS.map((t) => (
          <li>
            <a href={`/finance/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
