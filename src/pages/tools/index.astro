---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { CATEGORIES } from '../../lib/site';
import { QUANTITIES, allPairs, titleNoun } from '../../data/units';
import { CALCULATORS } from '../../data/calc/index';
import { SIZE_TOOLS } from '../../data/size/index';
import { TEXT_TOOLS } from '../../data/text/index';
import { COLOR_TOOLS } from '../../data/color/index';
import { CIPHER_TOOLS } from '../../data/cipher/index';
import { PRODUCTIVITY_TOOLS } from '../../data/productivity/index';
import { NETWORK_TOOLS } from '../../data/network/index';
import { MATH_TOOLS } from '../../data/math/index';
import { BIO_TOOLS } from '../../data/biology/index';
import { STAT_TOOLS } from '../../data/statistics/index';
import { CHEM_TOOLS } from '../../data/chemistry/index';
import { FILE_TOOLS } from '../../data/file/index';
import { DEV_TOOLS } from '../../data/dev/index';
import { GEN_TOOLS } from '../../data/generate/index';
import { TIME_TOOLS } from '../../data/time/index';
import { CALENDAR_TOOLS } from '../../data/calendar/index';
import { SECURITY_TOOLS } from '../../data/security/index';
import { IMAGE_TOOLS } from '../../data/image/index';
import { PDF_TOOLS } from '../../data/pdf/index';
import { AUDIO_TOOLS } from '../../data/video/index';
import { PHOTO_SPECS } from '../../data/photo/index';
import { breadcrumbSchema, collectionPageSchema } from '../../lib/schema';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'All Tools', url: '/tools/' },
];

const pairs = allPairs();
const soon = CATEGORIES.filter((c) => c.status === 'coming-soon');

const schema = [
  breadcrumbSchema(crumbs),
  collectionPageSchema({
    name: 'All LazyTools',
    url: '/tools/',
    description: 'Directory of every free, privacy-first tool on LazyTools.',
    items: [
      ...QUANTITIES.map((q) => ({ name: `${q.name} Converter`, url: `/units/${q.slug}/` })),
      ...pairs.map((p) => ({ name: `${titleNoun(p.from)} to ${titleNoun(p.to)} Converter`, url: `/units/${p.slug}/` })),
      ...CALCULATORS.map((c) => ({ name: c.name, url: `/calc/${c.slug}/` })),
      ...SIZE_TOOLS.map((t) => ({ name: t.name, url: `/size/${t.slug}/` })),
      ...TEXT_TOOLS.map((t) => ({ name: t.name, url: `/text/${t.slug}/` })),
      ...COLOR_TOOLS.map((t) => ({ name: t.name, url: `/color/${t.slug}/` })),
      ...FILE_TOOLS.map((t) => ({ name: t.name, url: `/file/${t.slug}/` })),
      ...DEV_TOOLS.map((t) => ({ name: t.name, url: `/dev/${t.slug}/` })),
      ...GEN_TOOLS.map((t) => ({ name: t.name, url: `/generate/${t.slug}/` })),
      ...TIME_TOOLS.map((t) => ({ name: t.name, url: `/time/${t.slug}/` })),
      ...CALENDAR_TOOLS.map((t) => ({ name: t.name, url: `/calendar/${t.slug}/` })),
      ...CIPHER_TOOLS.map((t) => ({ name: t.name, url: `/cipher/${t.slug}/` })),
      ...PRODUCTIVITY_TOOLS.map((t) => ({ name: t.name, url: `/productivity/${t.slug}/` })),
      ...NETWORK_TOOLS.map((t) => ({ name: t.name, url: `/network/${t.slug}/` })),
      ...MATH_TOOLS.map((t) => ({ name: t.name, url: `/math/${t.slug}/` })),
      ...BIO_TOOLS.map((t) => ({ name: t.name, url: `/biology/${t.slug}/` })),
      ...STAT_TOOLS.map((t) => ({ name: t.name, url: `/statistics/${t.slug}/` })),
      ...CHEM_TOOLS.map((t) => ({ name: t.name, url: `/chemistry/${t.slug}/` })),
      ...SECURITY_TOOLS.map((t) => ({ name: t.name, url: `/security/${t.slug}/` })),
      ...IMAGE_TOOLS.map((t) => ({ name: t.name, url: `/image/${t.slug}/` })),
      ...PHOTO_SPECS.map((s) => ({ name: `${s.label} Maker`, url: `/photo/${s.slug}/` })),
      ...PDF_TOOLS.map((t) => ({ name: t.name, url: `/pdf/${t.slug}/` })),
      ...AUDIO_TOOLS.map((t) => ({ name: t.name, url: `/video/${t.slug}/` })),
    ],
  }),
];
---

<Base
  title="All Tools — Complete Directory | LazyTools"
  description={`Every free, privacy-first tool on LazyTools in one place: ${QUANTITIES.length} unit converter categories with ${pairs.length}+ conversions. All tools run 100% in your browser.`}
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">All tools</h1>
    <p class="mt-3 max-w-3xl text-lg text-slate-700">
      The complete directory. Every tool is free, requires no sign-up, and processes your data locally in your
      browser.
    </p>

    <section class="mt-8">
      <h2 class="text-2xl font-bold text-slate-900">📐 Unit Converters</h2>
      {QUANTITIES.map((q) => (
        <div class="mt-6">
          <h3 class="font-semibold text-slate-900">
            <a href={`/units/${q.slug}/`} class="hover:text-brand-700 hover:underline">
              {q.icon} {q.name}
            </a>
          </h3>
          <ul class="mt-2 flex flex-wrap gap-2">
            {pairs
              .filter((p) => p.quantity.id === q.id)
              .map((p) => (
                <li>
                  <a
                    href={`/units/${p.slug}/`}
                    class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700"
                  >
                    {p.from.symbol} → {p.to.symbol}
                  </a>
                </li>
              ))}
          </ul>
        </div>
      ))}
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🧮 Calculators</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CALCULATORS.map((c) => (
          <li>
            <a
              href={`/calc/${c.slug}/`}
              class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700"
            >
              {c.icon} {c.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">💍 Size Converters</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {SIZE_TOOLS.map((t) => (
          <li>
            <a
              href={`/size/${t.slug}/`}
              class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700"
            >
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">✍️ Text Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {TEXT_TOOLS.map((t) => (
          <li>
            <a href={`/text/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🎨 Color Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {COLOR_TOOLS.map((t) => (
          <li>
            <a href={`/color/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📡 Codes & Ciphers</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CIPHER_TOOLS.map((t) => (
          <li>
            <a href={`/cipher/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🚀 Productivity</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {PRODUCTIVITY_TOOLS.map((t) => (
          <li>
            <a href={`/productivity/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">➗ Mathematics</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {MATH_TOOLS.map((t) => (
          <li>
            <a href={`/math/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🧬 Biology & Lab</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {BIO_TOOLS.map((t) => (
          <li>
            <a href={`/biology/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📈 Statistics</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {STAT_TOOLS.map((t) => (
          <li>
            <a href={`/statistics/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">⚗️ Chemistry & Lab</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CHEM_TOOLS.map((t) => (
          <li>
            <a href={`/chemistry/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🌐 Network & IT</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {NETWORK_TOOLS.map((t) => (
          <li>
            <a href={`/network/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🔄 File & Data Converters</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {FILE_TOOLS.map((t) => (
          <li>
            <a href={`/file/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">👨‍💻 Developer Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {DEV_TOOLS.map((t) => (
          <li>
            <a href={`/dev/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">✨ Generators</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {GEN_TOOLS.map((t) => (
          <li>
            <a href={`/generate/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📅 Date & Time Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {TIME_TOOLS.map((t) => (
          <li>
            <a href={`/time/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/time/zones/" class="inline-block rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-sm font-medium text-brand-800 transition hover:border-brand-400">
            🌍 Time-zone pairs (IST/EST/PST/GMT…)
          </a>
        </li>
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🗓️ Calendars</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CALENDAR_TOOLS.map((t) => (
          <li>
            <a href={`/calendar/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🔐 Privacy & Security</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {SECURITY_TOOLS.map((t) => (
          <li>
            <a href={`/security/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🖼️ Image Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {IMAGE_TOOLS.map((t) => (
          <li>
            <a href={`/image/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🪪 Photo Size Maker</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {PHOTO_SPECS.map((s) => (
          <li>
            <a href={`/photo/${s.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {s.flag} {s.label}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📄 PDF Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {PDF_TOOLS.map((t) => (
          <li>
            <a href={`/pdf/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🎬 Audio & Video</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {AUDIO_TOOLS.map((t) => (
          <li>
            <a href={`/video/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    {soon.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold text-slate-900">Coming soon</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {soon.map((c) => (
            <li class="rounded-xl border border-slate-200 p-4 opacity-70">
              <span class="text-xl grayscale" aria-hidden="true">{c.icon}</span>
              <p class="mt-1 font-semibold text-slate-700">{c.name}</p>
              <p class="text-sm text-slate-500">{c.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</Base>
