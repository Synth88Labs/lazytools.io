      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">☀️ Solar & Energy</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {SOLAR_TOOLS.map((t) => (
          <li>
            <a href={`/solar/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🍺 Homebrewing</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {BREWING_TOOLS.map((t) => (
          <li>
            <a href={`/brewing/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📸 Photography</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {PHOTOGRAPHY_TOOLS.map((t) => (
          <li>
            <a href={`/photography/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🔭 Astronomy & Space</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {ASTRO_TOOLS.map((t) => (
          <li>
            <a href={`/astronomy/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🌦️ Weather & Atmosphere</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
