---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { CATEGORIES, CATEGORY_GROUPS } from '../../lib/site';
import { QUANTITIES, allPairs, titleNoun } from '../../data/units';
import { CALCULATORS } from '../../data/calc/index';
import { SIZE_TOOLS } from '../../data/size/index';
import { TEXT_TOOLS } from '../../data/text/index';
import { COLOR_TOOLS } from '../../data/color/index';
import { CHART_TOOLS } from '../../data/charts/index';
import { CIPHER_TOOLS } from '../../data/cipher/index';
import { PRODUCTIVITY_TOOLS } from '../../data/productivity/index';
import { NETWORK_TOOLS } from '../../data/network/index';
import { MATH_TOOLS } from '../../data/math/index';
import { BIO_TOOLS } from '../../data/biology/index';
import { STAT_TOOLS } from '../../data/statistics/index';
import { CHEM_TOOLS } from '../../data/chemistry/index';
import { PHYS_TOOLS } from '../../data/physics/index';
import { HOME_TOOLS } from '../../data/home/index';
import { FIN_TOOLS } from '../../data/finance/index';
import { COOKING_TOOLS } from '../../data/cooking/index';
import { AUTO_TOOLS } from '../../data/automotive/index';
import { FITNESS_TOOLS } from '../../data/fitness/index';
import { PET_TOOLS } from '../../data/pets/index';
import { GARDEN_TOOLS } from '../../data/garden/index';
import { MUSIC_TOOLS } from '../../data/music/index';
import { WEATHER_TOOLS } from '../../data/weather/index';
import { ASTRO_TOOLS } from '../../data/astronomy/index';
import { PHOTOGRAPHY_TOOLS } from '../../data/photography/index';
import { ELECTRONICS_TOOLS } from '../../data/electronics/index';
import { TRAVEL_TOOLS } from '../../data/travel/index';
import { PRINTING3D_TOOLS } from '../../data/printing3d/index';
import { SOLAR_TOOLS } from '../../data/solar/index';
import { BREWING_TOOLS } from '../../data/brewing/index';
import { FILE_TOOLS } from '../../data/file/index';
import { DEV_TOOLS } from '../../data/dev/index';
import { GEN_TOOLS } from '../../data/generate/index';
import { TIME_TOOLS } from '../../data/time/index';
import { CALENDAR_TOOLS } from '../../data/calendar/index';
import { SECURITY_TOOLS } from '../../data/security/index';
import { IMAGE_TOOLS } from '../../data/image/index';
import { PDF_TOOLS } from '../../data/pdf/index';
import { AUDIO_TOOLS } from '../../data/video/index';
import { PHOTO_SPECS } from '../../data/photo/index';
import { breadcrumbSchema, collectionPageSchema } from '../../lib/schema';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'All Tools', url: '/tools/' },
];

const pairs = allPairs();
const soon = CATEGORIES.filter((c) => c.status === 'coming-soon');

const catBySlug = new Map(CATEGORIES.filter((c) => c.status === 'live').map((c) => [c.slug, c]));
const overviewGroups = CATEGORY_GROUPS.map((g) => ({
  ...g,
  cats: g.categories.map((s) => catBySlug.get(s)).filter((c): c is NonNullable<typeof c> => Boolean(c)),
})).filter((g) => g.cats.length > 0);

const schema = [
  breadcrumbSchema(crumbs),
  collectionPageSchema({
    name: 'All LazyTools',
    url: '/tools/',
    description: 'Directory of every free, privacy-first tool on LazyTools.',
    items: [
      ...QUANTITIES.map((q) => ({ name: `${q.name} Converter`, url: `/units/${q.slug}/` })),
      ...pairs.map((p) => ({ name: `${titleNoun(p.from)} to ${titleNoun(p.to)} Converter`, url: `/units/${p.slug}/` })),
      ...CALCULATORS.map((c) => ({ name: c.name, url: `/calc/${c.slug}/` })),
      ...SIZE_TOOLS.map((t) => ({ name: t.name, url: `/size/${t.slug}/` })),
      ...TEXT_TOOLS.map((t) => ({ name: t.name, url: `/text/${t.slug}/` })),
      ...COLOR_TOOLS.map((t) => ({ name: t.name, url: `/color/${t.slug}/` })),
      ...CHART_TOOLS.map((t) => ({ name: t.name, url: `/charts/${t.slug}/` })),
      ...FILE_TOOLS.map((t) => ({ name: t.name, url: `/file/${t.slug}/` })),
      ...DEV_TOOLS.map((t) => ({ name: t.name, url: `/dev/${t.slug}/` })),
      ...GEN_TOOLS.map((t) => ({ name: t.name, url: `/generate/${t.slug}/` })),
      ...TIME_TOOLS.map((t) => ({ name: t.name, url: `/time/${t.slug}/` })),
      ...CALENDAR_TOOLS.map((t) => ({ name: t.name, url: `/calendar/${t.slug}/` })),
      ...CIPHER_TOOLS.map((t) => ({ name: t.name, url: `/cipher/${t.slug}/` })),
      ...PRODUCTIVITY_TOOLS.map((t) => ({ name: t.name, url: `/productivity/${t.slug}/` })),
      ...NETWORK_TOOLS.map((t) => ({ name: t.name, url: `/network/${t.slug}/` })),
      ...MATH_TOOLS.map((t) => ({ name: t.name, url: `/math/${t.slug}/` })),
      ...BIO_TOOLS.map((t) => ({ name: t.name, url: `/biology/${t.slug}/` })),
      ...STAT_TOOLS.map((t) => ({ name: t.name, url: `/statistics/${t.slug}/` })),
      ...CHEM_TOOLS.map((t) => ({ name: t.name, url: `/chemistry/${t.slug}/` })),
      ...PHYS_TOOLS.map((t) => ({ name: t.name, url: `/physics/${t.slug}/` })),
      ...HOME_TOOLS.map((t) => ({ name: t.name, url: `/home/${t.slug}/` })),
      ...FIN_TOOLS.map((t) => ({ name: t.name, url: `/finance/${t.slug}/` })),
      ...COOKING_TOOLS.map((t) => ({ name: t.name, url: `/cooking/${t.slug}/` })),
      ...AUTO_TOOLS.map((t) => ({ name: t.name, url: `/automotive/${t.slug}/` })),
      ...FITNESS_TOOLS.map((t) => ({ name: t.name, url: `/fitness/${t.slug}/` })),
      ...PET_TOOLS.map((t) => ({ name: t.name, url: `/pets/${t.slug}/` })),
      ...GARDEN_TOOLS.map((t) => ({ name: t.name, url: `/garden/${t.slug}/` })),
      ...MUSIC_TOOLS.map((t) => ({ name: t.name, url: `/music/${t.slug}/` })),
      ...WEATHER_TOOLS.map((t) => ({ name: t.name, url: `/weather/${t.slug}/` })),
      ...ASTRO_TOOLS.map((t) => ({ name: t.name, url: `/astronomy/${t.slug}/` })),
      ...PHOTOGRAPHY_TOOLS.map((t) => ({ name: t.name, url: `/photography/${t.slug}/` })),
      ...ELECTRONICS_TOOLS.map((t) => ({ name: t.name, url: `/electronics/${t.slug}/` })),
      ...TRAVEL_TOOLS.map((t) => ({ name: t.name, url: `/travel/${t.slug}/` })),
      ...PRINTING3D_TOOLS.map((t) => ({ name: t.name, url: `/3d-printing/${t.slug}/` })),
      ...SOLAR_TOOLS.map((t) => ({ name: t.name, url: `/solar/${t.slug}/` })),
      ...BREWING_TOOLS.map((t) => ({ name: t.name, url: `/brewing/${t.slug}/` })),
      ...SECURITY_TOOLS.map((t) => ({ name: t.name, url: `/security/${t.slug}/` })),
      ...IMAGE_TOOLS.map((t) => ({ name: t.name, url: `/image/${t.slug}/` })),
      ...PHOTO_SPECS.map((s) => ({ name: `${s.label} Maker`, url: `/photo/${s.slug}/` })),
      ...PDF_TOOLS.map((t) => ({ name: t.name, url: `/pdf/${t.slug}/` })),
      ...AUDIO_TOOLS.map((t) => ({ name: t.name, url: `/video/${t.slug}/` })),
    ],
  }),
];
---

<Base
  title="All Tools — Complete Directory | LazyTools"
  description={`Every free, privacy-first tool on LazyTools in one place: ${QUANTITIES.length} unit converter categories with ${pairs.length}+ conversions. All tools run 100% in your browser.`}
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">All tools</h1>
    <p class="mt-3 max-w-3xl text-lg text-slate-700">
      The complete directory. Every tool is free, requires no sign-up, and processes your data locally in your
      browser — nothing you type, upload or calculate is ever sent to a server.
    </p>
    <!-- Live filter -->
    <div class="mt-6">
      <label class="relative block max-w-2xl">
        <span class="sr-only">Filter tools by name</span>
        <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" /></svg>
        <input id="tools-filter" type="search" autocomplete="off" placeholder="Filter tools — try “pdf”, “percentage”, “color”…" class="w-full rounded-2xl border border-slate-300 bg-white py-3.5 pl-12 pr-4 text-base text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200" />
      </label>
      <p id="tools-filter-status" class="mt-2 text-sm text-slate-500" aria-live="polite"></p>
    </div>

    <!-- Grouped category overview -->
    <nav aria-label="Tool categories" class="mt-6" id="tools-overview">
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {overviewGroups.map((g) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-4">
            <p class="flex items-center gap-2 text-sm font-bold text-slate-900">
              <span aria-hidden="true" class="text-lg">{g.icon}</span>{g.name}
            </p>
            <p class="mt-0.5 text-xs text-slate-500">{g.blurb}</p>
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {g.cats.map((c) => (
                <li>
                  <a href={`/${c.slug}/`} class="inline-flex items-center gap-1 rounded-lg bg-slate-50 px-2.5 py-1.5 text-xs font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-brand-50 hover:text-brand-800 hover:ring-brand-300">
                    <span aria-hidden="true">{c.icon}</span>{c.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="mt-4 max-w-3xl text-sm text-slate-500">
        🔒 Every tool runs 100% in your browser and keeps working offline — nothing you type or upload is sent to a server.
        Converters use internationally defined factors; the science tools show exact working. Start typing above to filter, or browse the full lists below.
      </p>
    </nav>

    <p id="tools-empty" class="mt-8 hidden rounded-xl border border-slate-200 bg-slate-50 p-6 text-center text-slate-500">
      No tools match your filter. Try a shorter or different term.
    </p>

    <div id="tools-list">
    <section class="mt-8">
      <h2 class="text-2xl font-bold text-slate-900">📐 Unit Converters</h2>
      {QUANTITIES.map((q) => (
        <div class="mt-6">
          <h3 class="font-semibold text-slate-900">
            <a href={`/units/${q.slug}/`} class="hover:text-brand-700 hover:underline">
              {q.icon} {q.name}
            </a>
          </h3>
          <ul class="mt-2 flex flex-wrap gap-2">
            {pairs
              .filter((p) => p.quantity.id === q.id)
              .map((p) => (
                <li>
                  <a
                    href={`/units/${p.slug}/`}
                    class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700"
                  >
                    {p.from.symbol} → {p.to.symbol}
                  </a>
                </li>
              ))}
          </ul>
        </div>
      ))}
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🧮 Calculators</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CALCULATORS.map((c) => (
          <li>
            <a
              href={`/calc/${c.slug}/`}
              class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700"
            >
              {c.icon} {c.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">💍 Size Converters</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {SIZE_TOOLS.map((t) => (
          <li>
            <a
              href={`/size/${t.slug}/`}
              class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700"
            >
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">✍️ Text Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {TEXT_TOOLS.map((t) => (
          <li>
            <a href={`/text/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🎨 Color Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {COLOR_TOOLS.map((t) => (
          <li>
            <a href={`/color/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📊 Charts & Design</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CHART_TOOLS.map((t) => (
          <li>
            <a href={`/charts/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📡 Codes & Ciphers</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CIPHER_TOOLS.map((t) => (
          <li>
            <a href={`/cipher/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🚀 Productivity</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {PRODUCTIVITY_TOOLS.map((t) => (
          <li>
            <a href={`/productivity/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">➗ Mathematics</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {MATH_TOOLS.map((t) => (
          <li>
            <a href={`/math/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🧬 Biology & Lab</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {BIO_TOOLS.map((t) => (
          <li>
            <a href={`/biology/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📈 Statistics</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {STAT_TOOLS.map((t) => (
          <li>
            <a href={`/statistics/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">⚗️ Chemistry & Lab</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {CHEM_TOOLS.map((t) => (
          <li>
            <a href={`/chemistry/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">🧲 Physics</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {PHYS_TOOLS.map((t) => (
          <li>
            <a href={`/physics/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
