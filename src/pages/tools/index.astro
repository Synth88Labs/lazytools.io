    <section class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900">📅 Date & Time Tools</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {TIME_TOOLS.map((t) => (
          <li>
            <a href={`/time/${t.slug}/`} class="inline-block rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition hover:border-brand-400 hover:text-brand-700">
              {t.icon} {t.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/time/zones/" class="inline-block rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-sm font-medium text-brand-800 transition hover:border-brand-400">
            🌍 Time-zone pairs (IST/EST/PST/GMT…)
          </a>
