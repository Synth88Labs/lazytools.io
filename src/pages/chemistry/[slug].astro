---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import MolarMassTool from '../../components/chemistry/MolarMassTool.tsx';
import WeakAcidTool from '../../components/chemistry/WeakAcidTool.tsx';
import KspTool from '../../components/chemistry/KspTool.tsx';
import EquilibriumTool from '../../components/chemistry/EquilibriumTool.tsx';
import HessLawTool from '../../components/chemistry/HessLawTool.tsx';
import EquationBalancerTool from '../../components/chemistry/EquationBalancerTool.tsx';
import MolarityTool from '../../components/chemistry/MolarityTool.tsx';
import IdealGasTool from '../../components/chemistry/IdealGasTool.tsx';
import SpecificHeatTool from '../../components/chemistry/SpecificHeatTool.tsx';
import PhTool from '../../components/chemistry/PhTool.tsx';
import StoichiometryTool from '../../components/chemistry/StoichiometryTool.tsx';
import MoleTool from '../../components/chemistry/MoleTool.tsx';
import EmpiricalFormulaTool from '../../components/chemistry/EmpiricalFormulaTool.tsx';
import PercentYieldTool from '../../components/chemistry/PercentYieldTool.tsx';
import DilutionTool from '../../components/chemistry/DilutionTool.tsx';
import DensityTool from '../../components/chemistry/DensityTool.tsx';
import HendersonTool from '../../components/chemistry/HendersonTool.tsx';
import BeerLambertTool from '../../components/chemistry/BeerLambertTool.tsx';
import CombinedGasTool from '../../components/chemistry/CombinedGasTool.tsx';
import HalfLifeTool from '../../components/chemistry/HalfLifeTool.tsx';
import GibbsFreeEnergyTool from '../../components/chemistry/GibbsFreeEnergyTool.tsx';
import NernstTool from '../../components/chemistry/NernstTool.tsx';
import ArrheniusTool from '../../components/chemistry/ArrheniusTool.tsx';
import FreezingPointTool from '../../components/chemistry/FreezingPointTool.tsx';
import BoilingPointTool from '../../components/chemistry/BoilingPointTool.tsx';
import PpmTool from '../../components/chemistry/PpmTool.tsx';
import PercentErrorTool from '../../components/chemistry/PercentErrorTool.tsx';
import PeriodicTableTool from '../../components/chemistry/PeriodicTableTool.tsx';
import ElectronConfigTool from '../../components/chemistry/ElectronConfigTool.tsx';
import ElementComparisonTool from '../../components/chemistry/ElementComparisonTool.tsx';
import AverageAtomicMassTool from '../../components/chemistry/AverageAtomicMassTool.tsx';
import OxidationNumberTool from '../../components/chemistry/OxidationNumberTool.tsx';
import { CHEM_TOOLS, type ChemToolDef } from '../../data/chemistry/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return CHEM_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: ChemToolDef = CHEM_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Chemistry & Lab', url: '/chemistry/' },
  { name: tool.name, url: `/chemistry/${tool.slug}/` },
];

const related = CHEM_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/chemistry/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/chemistry/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`chemistry/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'molarmass' && <MolarMassTool client:load view={tool.view ?? 'mass'} />}
      {tool.widget === 'balancer' && <EquationBalancerTool client:load />}
      {tool.widget === 'molarity' && <MolarityTool client:load />}
      {tool.widget === 'idealgas' && <IdealGasTool client:load />}
      {tool.widget === 'specheat' && <SpecificHeatTool client:load />}
      {tool.widget === 'ph' && <PhTool client:load />}
      {tool.widget === 'stoich' && <StoichiometryTool client:load />}
      {tool.widget === 'mole' && <MoleTool client:load />}
      {tool.widget === 'empirical' && <EmpiricalFormulaTool client:load />}
      {tool.widget === 'yield' && <PercentYieldTool client:load />}
      {tool.widget === 'dilution' && <DilutionTool client:load />}
      {tool.widget === 'density' && <DensityTool client:load />}
      {tool.widget === 'henderson' && <HendersonTool client:load />}
      {tool.widget === 'beerlambert' && <BeerLambertTool client:load />}
      {tool.widget === 'gaslaw' && <CombinedGasTool client:load />}
      {tool.widget === 'halflife' && <HalfLifeTool client:load />}
      {tool.widget === 'gibbs' && <GibbsFreeEnergyTool client:load />}
      {tool.widget === 'nernst' && <NernstTool client:load />}
      {tool.widget === 'arrhenius' && <ArrheniusTool client:load />}
      {tool.widget === 'freezing' && <FreezingPointTool client:load />}
      {tool.widget === 'boiling' && <BoilingPointTool client:load />}
      {tool.widget === 'ppm' && <PpmTool client:load />}
      {tool.widget === 'percenterror' && <PercentErrorTool client:load />}
      {tool.widget === 'periodic' && <PeriodicTableTool client:load />}
      {tool.widget === 'econfig' && <ElectronConfigTool client:load />}
      {tool.widget === 'compare' && <ElementComparisonTool client:load />}
      {tool.widget === 'isotope' && <AverageAtomicMassTool client:load />}
      {tool.widget === 'oxidation' && <OxidationNumberTool client:load />}
      {tool.widget === 'weakacid' && <WeakAcidTool client:load />}
      {tool.widget === 'ksp' && <KspTool client:load />}
      {tool.widget === 'kc' && <EquilibriumTool client:load />}
      {tool.widget === 'hess' && <HessLawTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`chemistry/${tool.slug}`}
        avg={ratingFor(`chemistry/${tool.slug}`)?.avg}
        count={ratingFor(`chemistry/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related chemistry tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/chemistry/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/chemistry/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All chemistry tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
