---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import HeatIndexTool from '../../components/weather/HeatIndexTool.tsx';
import WindChillTool from '../../components/weather/WindChillTool.tsx';
import DewPointTool from '../../components/weather/DewPointTool.tsx';
import AbsoluteHumidityTool from '../../components/weather/AbsoluteHumidityTool.tsx';
import VpdTool from '../../components/weather/VpdTool.tsx';
import RainfallTool from '../../components/weather/RainfallTool.tsx';
import HumidityTool from '../../components/weather/HumidityTool.tsx';
import FeelsLikeTool from '../../components/weather/FeelsLikeTool.tsx';
import WetBulbTool from '../../components/weather/WetBulbTool.tsx';
import BeaufortTool from '../../components/weather/BeaufortTool.tsx';
import CloudBaseTool from '../../components/weather/CloudBaseTool.tsx';
import { WEATHER_TOOLS, type WeatherToolDef } from '../../data/weather/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return WEATHER_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: WeatherToolDef = WEATHER_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weather & Atmosphere', url: '/weather/' },
  { name: tool.name, url: `/weather/${tool.slug}/` },
];

const related = WEATHER_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/weather/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/weather/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`weather/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'heatindex' && <HeatIndexTool client:load />}
      {tool.widget === 'windchill' && <WindChillTool client:load />}
      {tool.widget === 'dewpoint' && <DewPointTool client:load />}
      {tool.widget === 'abshumidity' && <AbsoluteHumidityTool client:load />}
      {tool.widget === 'vpd' && <VpdTool client:load />}
      {tool.widget === 'rainfall' && <RainfallTool client:load />}
      {tool.widget === 'humidity' && <HumidityTool client:load />}
      {tool.widget === 'feelslike' && <FeelsLikeTool client:load />}
      {tool.widget === 'wetbulb' && <WetBulbTool client:load />}
      {tool.widget === 'beaufort' && <BeaufortTool client:load />}
      {tool.widget === 'cloudbase' && <CloudBaseTool client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`weather/${tool.slug}`}
        avg={ratingFor(`weather/${tool.slug}`)?.avg}
        count={ratingFor(`weather/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related weather tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/weather/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/weather/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All weather tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
