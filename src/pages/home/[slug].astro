---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PrivacyStrip from '../../components/PrivacyStrip.astro';
import FaqSection from '../../components/FaqSection.astro';
import RatingWidget from '../../components/RatingWidget.tsx';
import PaintCalculator from '../../components/home/PaintCalculator.tsx';
import StairCalculator from '../../components/home/StairCalculator.tsx';
import StudCalculator from '../../components/home/StudCalculator.tsx';
import BtuCalculator from '../../components/home/BtuCalculator.tsx';
import TileCalculator from '../../components/home/TileCalculator.tsx';
import ConcreteCalculator from '../../components/home/ConcreteCalculator.tsx';
import MulchCalculator from '../../components/home/MulchCalculator.tsx';
import WallpaperCalculator from '../../components/home/WallpaperCalculator.tsx';
import GravelCalculator from '../../components/home/GravelCalculator.tsx';
import DrywallCalculator from '../../components/home/DrywallCalculator.tsx';
import RoofingCalculator from '../../components/home/RoofingCalculator.tsx';
import LawnCalculator from '../../components/home/LawnCalculator.tsx';
import FenceCalculator from '../../components/home/FenceCalculator.tsx';
import DeckCalculator from '../../components/home/DeckCalculator.tsx';
import BoardFootCalculator from '../../components/home/BoardFootCalculator.tsx';
import { HOME_TOOLS, type HomeToolDef } from '../../data/home/index';
import { breadcrumbSchema, webApplicationSchema, faqSchema } from '../../lib/schema';
import { ratingFor } from '../../lib/ratings';

export function getStaticPaths() {
  return HOME_TOOLS.map((t) => ({ params: { slug: t.slug }, props: { slug: t.slug } }));
}

const { slug } = Astro.props;
const tool: HomeToolDef = HOME_TOOLS.find((t) => t.slug === slug)!;

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Home & DIY', url: '/home/' },
  { name: tool.name, url: `/home/${tool.slug}/` },
];

const related = HOME_TOOLS.filter((t) => t.slug !== tool.slug).slice(0, 6);
const allBlogPosts = await getCollection('blog');
const blogPosts = allBlogPosts.filter((p) => p.data.tools.includes(`/home/${tool.slug}/`));

const schema = [
  breadcrumbSchema(crumbs),
  webApplicationSchema({
    name: tool.name,
    url: `/home/${tool.slug}/`,
    description: tool.description,
    rating: ratingFor(`home/${tool.slug}`),
  }),
  faqSchema(tool.faqs),
];
---

<Base title={`${tool.name} — Free & Private | LazyTools`} description={tool.description} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      {tool.icon} {tool.name}
    </h1>

    <p class="mt-3 text-lg leading-relaxed text-slate-700">
      <strong class="font-semibold text-slate-900">{tool.lead}</strong>
    </p>

    <div class="mt-6">
      {tool.widget === 'paint' && <PaintCalculator client:load />}
      {tool.widget === 'stair' && <StairCalculator client:load />}
      {tool.widget === 'stud' && <StudCalculator client:load />}
      {tool.widget === 'btu' && <BtuCalculator client:load />}
      {tool.widget === 'tile' && <TileCalculator client:load />}
      {tool.widget === 'concrete' && <ConcreteCalculator client:load />}
      {tool.widget === 'mulch' && <MulchCalculator client:load />}
      {tool.widget === 'wallpaper' && <WallpaperCalculator client:load />}
      {tool.widget === 'gravel' && <GravelCalculator client:load />}
      {tool.widget === 'drywall' && <DrywallCalculator client:load />}
      {tool.widget === 'roofing' && <RoofingCalculator client:load />}
      {tool.widget === 'lawn' && <LawnCalculator client:load />}
      {tool.widget === 'fence' && <FenceCalculator client:load />}
      {tool.widget === 'deck' && <DeckCalculator client:load />}
      {tool.widget === 'boardfoot' && <BoardFootCalculator client:load />}
    </div>

    <div class="mt-4">
      <PrivacyStrip />
    </div>

    <div class="mt-3">
      <RatingWidget
        client:idle
        toolSlug={`home/${tool.slug}`}
        avg={ratingFor(`home/${tool.slug}`)?.avg}
        count={ratingFor(`home/${tool.slug}`)?.count}
      />
    </div>

    <section class="prose-lazy mt-6">
      <h2>How the {tool.name.toLowerCase()} works</h2>
      <p>{tool.how}</p>
      {tool.note && <p>{tool.note}</p>}
    </section>

    <FaqSection faqs={tool.faqs} />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-slate-900">Related home & DIY tools</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/home/${r.slug}/`} class="block rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
              {r.icon} {r.name}
            </a>
          </li>
        ))}
        <li>
          <a href="/home/" class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-brand-400">
            All home & DIY tools →
          </a>
        </li>
      </ul>
    </section>

    {
      blogPosts.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-slate-900">From the blog</h2>
          <ul class="mt-4 space-y-3">
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="block rounded-xl border border-slate-200 p-4 transition hover:border-brand-400 hover:shadow-sm">
                  <p class="font-semibold text-slate-900">{post.data.title}</p>
                  <p class="mt-1 text-sm text-slate-600">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
