---
import '../styles/global.css';
import { SITE } from '../lib/site';
import { organizationSchema, websiteSchema } from '../lib/schema';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Additional JSON-LD blocks for this page */
  schema?: Record<string, unknown>[];
  noindex?: boolean;
  /** Path to a social share image (1200×630), e.g. /blog/kg-to-lbs-guide.png */
  image?: string;
}

const { title, description, schema = [], noindex = false, image } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const imageUrl = image ? new URL(image, SITE.url).href : undefined;
const allSchema = [organizationSchema(), websiteSchema(), ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) with Consent Mode v2 — analytics denied until the visitor accepts -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-ZXNK938YR8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      // Default: no analytics or ad storage until the user consents (GDPR/ePrivacy).
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
      // Restore a previously granted choice so returning visitors aren't re-asked.
      try { if (localStorage.getItem('lt-consent') === 'granted') gtag('consent', 'update', { analytics_storage: 'granted' }); } catch (e) {}
      gtag('js', new Date());
      gtag('config', 'G-ZXNK938YR8');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1d87f1" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {imageUrl && <meta property="og:image:width" content="1200" />}
    {imageUrl && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {allSchema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Cookie consent banner (Consent Mode v2). Hidden until JS confirms no prior choice. -->
    <div
      id="cookie-consent"
      hidden
      class="fixed inset-x-0 bottom-0 z-[60] border-t border-slate-200 bg-white/95 backdrop-blur-md shadow-[0_-4px_16px_rgba(0,0,0,0.06)]"
    >
      <div class="mx-auto flex max-w-5xl flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center">
        <p class="flex-1 text-sm text-slate-600">
          🍪 We use <strong class="font-semibold text-slate-800">Google Analytics</strong> cookies to measure page visits. Anything you type or process in a tool stays on your device either way. <a href="/cookies/" class="underline underline-offset-2 hover:text-brand-700">Details</a>.
        </p>
        <div class="flex gap-2">
          <button id="cc-decline" class="rounded-lg border border-slate-300 bg-white px-4 py-1.5 text-sm font-semibold text-slate-700 hover:border-brand-400">Decline</button>
          <button id="cc-accept" class="rounded-lg bg-brand-700 px-4 py-1.5 text-sm font-semibold text-white hover:bg-brand-800">Accept</button>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        var el = document.getElementById('cookie-consent');
        if (!el) return;
        var stored = null;
        try { stored = localStorage.getItem('lt-consent'); } catch (e) {}
        if (!stored) el.hidden = false;
        function choose(v) {
          try { localStorage.setItem('lt-consent', v); } catch (e) {}
          if (v === 'granted' && typeof gtag === 'function') gtag('consent', 'update', { analytics_storage: 'granted' });
          el.hidden = true;
        }
        var a = document.getElementById('cc-accept');
        var d = document.getElementById('cc-decline');
        if (a) a.addEventListener('click', function () { choose('granted'); });
        if (d) d.addEventListener('click', function () { choose('denied'); });
      })();
    </script>

    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-50 hidden h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-lg text-slate-600 shadow-lg transition hover:border-brand-400 hover:text-brand-700 hover:shadow-xl"
    >
      ↑
    </button>
    <script>
      const btn = document.getElementById('back-to-top')!;
      const toggle = () => {
        btn.classList.toggle('hidden', window.scrollY < 400);
        btn.classList.toggle('flex', window.scrollY >= 400);
      };
      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
      btn.addEventListener('click', () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
      });
    </script>
  </body>
</html>
