---
import Base from './Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  updated?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>[];
}

const { title, description, heading, updated, noindex = false, schema = [] } = Astro.props;
const path = Astro.url.pathname;
const crumbs = [
  { name: 'Home', url: '/' },
  { name: heading, url: path },
];
---

<Base title={title} description={description} noindex={noindex} schema={schema}>
  <article class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{heading}</h1>
    {updated && <p class="mt-2 text-sm text-slate-500">Last updated: {updated}</p>}
    <div class="prose-lazy mt-6">
      <slot />
    </div>
  </article>
</Base>
