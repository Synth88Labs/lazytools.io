---
interface Props {
  faqs: { q: string; a: string }[];
  heading?: string;
}
const { faqs, heading = 'Frequently asked questions' } = Astro.props;
---

<section class="mt-10">
  <h2 class="text-2xl font-bold text-slate-900">{heading}</h2>
  <div class="mt-4 divide-y divide-slate-200 rounded-xl border border-slate-200">
    {faqs.map((f) => (
      <details class="group p-4">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-2 font-medium text-slate-900">
          {f.q}
          <span class="text-slate-400 transition-transform group-open:rotate-45" aria-hidden="true">＋</span>
        </summary>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">{f.a}</p>
      </details>
    ))}
  </div>
</section>
