---
import { CATEGORIES, SITE } from '../lib/site';
const live = CATEGORIES.filter((c) => c.status === 'live');
const soon = CATEGORIES.filter((c) => c.status === 'coming-soon').slice(0, 6);
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-slate-200 bg-slate-50">
  <div class="mx-auto grid max-w-5xl gap-8 px-4 py-10 sm:grid-cols-2 lg:grid-cols-5">
    <div>
      <p class="flex items-center gap-2 text-lg font-extrabold text-slate-900">
        <img src="/logo.svg" alt="" width="24" height="24" class="h-6 w-6" />
        Lazy<span class="text-brand-700">Tools</span>
      </p>
      <p class="mt-2 text-sm leading-relaxed text-slate-600">
        {SITE.tagline}. Every tool processes your data locally — nothing ever leaves your device.
      </p>
    </div>
    <div class="sm:col-span-2">
      <p class="text-sm font-semibold text-slate-900">Tool categories</p>
      <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1.5 text-sm text-slate-600 sm:grid-cols-3">
        {live.map((c) => (
          <li><a href={`/${c.slug}/`} class="hover:text-brand-700">{c.name}</a></li>
        ))}
        {soon.map((c) => (
          <li><span class="text-slate-500">{c.name} <span class="text-xs">(soon)</span></span></li>
        ))}
      </ul>
      <a href="/tools/" class="mt-3 inline-block rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-brand-400 hover:text-brand-700">
        Browse all tools →
      </a>
    </div>
    <div>
      <p class="text-sm font-semibold text-slate-900">Company</p>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        <li><a href="/about/" class="hover:text-brand-700">About</a></li>
        <li><a href="/blog/" class="hover:text-brand-700">Blog</a></li>
        <li><a href="/how-it-works/" class="hover:text-brand-700">How it works</a></li>
        <li><a href="/contact/" class="hover:text-brand-700">Contact</a></li>
        <li><a href={SITE.github} rel="noopener" class="hover:text-brand-700">GitHub — we're open source</a></li>
        <li><a href="/licenses/" class="hover:text-brand-700">Open-source licenses</a></li>
      </ul>
    </div>
    <div>
      <p class="text-sm font-semibold text-slate-900">Legal</p>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        <li><a href="/privacy/" class="hover:text-brand-700">Privacy policy</a></li>
        <li><a href="/terms/" class="hover:text-brand-700">Terms of service</a></li>
        <li><a href="/cookies/" class="hover:text-brand-700">Cookie statement</a></li>
        <li><a href="/disclaimer/" class="hover:text-brand-700">Disclaimer</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-slate-200">
    <p class="mx-auto max-w-5xl px-4 py-4 text-xs text-slate-500">
      © {year} {SITE.domain} · Free, privacy-first browser tools ·
      A <a href={SITE.parent.url} rel="noopener" class="font-medium underline underline-offset-2 hover:text-brand-700">{SITE.parent.name}</a> project ·
      <a href={SITE.github} rel="noopener" class="font-medium underline underline-offset-2 hover:text-brand-700">Open source on GitHub</a>
    </p>
  </div>
</footer>
