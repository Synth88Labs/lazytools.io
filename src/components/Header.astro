---
import SearchBox from './SearchBox.tsx';
import { buildSearchQuantities, buildSearchPages } from '../lib/search-data';
import { CATEGORIES } from '../lib/site';

const quantities = buildSearchQuantities();
const pages = buildSearchPages();
const liveCategories = CATEGORIES.filter((c) => c.status === 'live');

const NAV = [
  { href: '/tools/', label: 'All Tools' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
---

<header class="z-40 border-b border-slate-200 bg-white/90 backdrop-blur-md sm:sticky sm:top-0">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center gap-x-4 gap-y-2 px-4 py-3">
    <a href="/" class="flex items-center gap-2 text-xl font-extrabold tracking-tight text-slate-900">
      <img src="/logo-animated.svg" alt="" width="32" height="32" class="h-8 w-8" />
      <span>Lazy<span class="text-brand-700">Tools</span></span>
    </a>

    <button
      id="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Open menu"
      class="ml-auto flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-700 sm:hidden"
    >
      <svg id="nav-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="nav-icon-close" class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <div class="order-3 w-full sm:order-2 sm:w-auto sm:flex-1 sm:px-2 lg:px-6">
      <SearchBox client:idle quantities={quantities} pages={pages} />
    </div>

    <nav id="site-nav" aria-label="Main navigation" class="order-4 hidden w-full sm:order-3 sm:ml-auto sm:block sm:w-auto">
      <ul class="flex flex-col gap-1 border-t border-slate-100 pt-2 pb-1 text-base font-medium text-slate-700 sm:flex-row sm:items-center sm:gap-2 sm:border-0 sm:p-0 sm:text-sm">
        <li class="sm:relative">
          <details id="cat-menu">
            <summary class="flex cursor-pointer list-none items-center gap-1 rounded-lg px-3 py-2.5 hover:bg-slate-100 hover:text-slate-900 sm:py-2 [&::-webkit-details-marker]:hidden">
              Categories
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </summary>
            <ul class="grid gap-0.5 pb-1 pl-3 sm:absolute sm:right-0 sm:top-full sm:z-50 sm:mt-1 sm:w-[28rem] sm:grid-cols-2 sm:gap-1 sm:rounded-xl sm:border sm:border-slate-200 sm:bg-white sm:p-2 sm:pl-2 sm:shadow-lg">
              {liveCategories.map((c) => (
                <li>
                  <a href={`/${c.slug}/`} class="flex items-center gap-2 rounded-lg px-3 py-2 hover:bg-slate-100 hover:text-slate-900">
                    <span aria-hidden="true">{c.icon}</span>
                    {c.name}
                  </a>
                </li>
              ))}
              <li class="sm:col-span-2">
                <a href="/tools/" class="block rounded-lg px-3 py-2 font-semibold text-brand-700 hover:bg-brand-50">
                  All tools directory →
                </a>
              </li>
            </ul>
          </details>
        </li>
        {NAV.map((item) => (
          <li>
            <a href={item.href} class="block rounded-lg px-3 py-2.5 hover:bg-slate-100 hover:text-slate-900 sm:py-2">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="bg-mint-600/10 border-t border-mint-600/20">
    <p class="mx-auto max-w-5xl px-4 py-1.5 text-center text-xs font-medium text-mint-700">
      🔒 Everything on LazyTools runs in your browser — your data is never uploaded to any server.
      <a href="/how-it-works/" class="underline underline-offset-2 hover:text-mint-600">How it works</a>
    </p>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const nav = document.getElementById('site-nav')!;
  const iconOpen = document.getElementById('nav-icon-open')!;
  const iconClose = document.getElementById('nav-icon-close')!;
  toggle.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    toggle.setAttribute('aria-label', expanded ? 'Open menu' : 'Close menu');
    nav.classList.toggle('hidden', expanded);
    iconOpen.classList.toggle('hidden', !expanded);
    iconClose.classList.toggle('hidden', expanded);
  });

  const catMenu = document.getElementById('cat-menu');
  if (catMenu) {
    document.addEventListener('click', (e) => {
      if (catMenu.hasAttribute('open') && !catMenu.contains(e.target as Node)) catMenu.removeAttribute('open');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') catMenu.removeAttribute('open');
    });
  }
</script>
