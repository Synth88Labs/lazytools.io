---
import SearchBox from './SearchBox.tsx';
import { buildSearchQuantities, buildSearchPages } from '../lib/search-data';

const quantities = buildSearchQuantities();
const pages = buildSearchPages();
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-4 gap-y-2 px-4 py-3">
    <a href="/" class="flex items-center gap-2 text-xl font-extrabold tracking-tight text-slate-900">
      <img src="/logo-animated.svg" alt="" width="32" height="32" class="h-8 w-8" />
      <span>Lazy<span class="text-brand-700">Tools</span></span>
    </a>
    <div class="order-3 w-full sm:order-2 sm:w-auto sm:flex-1 sm:px-2 lg:px-6">
      <SearchBox client:idle quantities={quantities} pages={pages} />
    </div>
    <nav aria-label="Main navigation" class="order-2 ml-auto sm:order-3">
      <ul class="flex items-center gap-1 text-sm font-medium text-slate-700 sm:gap-2">
        <li><a href="/units/" class="rounded-lg px-3 py-2 hover:bg-slate-100 hover:text-slate-900">Unit Converters</a></li>
        <li><a href="/tools/" class="rounded-lg px-3 py-2 hover:bg-slate-100 hover:text-slate-900">All Tools</a></li>
        <li><a href="/blog/" class="rounded-lg px-3 py-2 hover:bg-slate-100 hover:text-slate-900">Blog</a></li>
        <li class="hidden sm:block"><a href="/about/" class="rounded-lg px-3 py-2 hover:bg-slate-100 hover:text-slate-900">About</a></li>
      </ul>
    </nav>
  </div>
  <div class="bg-mint-600/10 border-t border-mint-600/20">
    <p class="mx-auto max-w-6xl px-4 py-1.5 text-center text-xs font-medium text-mint-700">
      🔒 Everything on LazyTools runs in your browser — your data is never uploaded to any server.
      <a href="/how-it-works/" class="underline underline-offset-2 hover:text-mint-600">How it works</a>
    </p>
  </div>
</header>
